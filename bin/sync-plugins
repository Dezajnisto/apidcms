#!/bin/bash
# sync-plugins — синхронизация плагинов из центральных репо в проекты
set -e

PLUGINS_DIR=/home/c91469/plugins

if [ $# -eq 0 ]; then
    echo "Использование: sync-plugins <plugin> [project1 project2 ...]"
    echo "               sync-plugins <plugin> all"
    echo "Плагины: $(ls -m $PLUGINS_DIR 2>/dev/null)"
    exit 1
fi

PLUGIN="$1"
shift

if [ ! -d "$PLUGINS_DIR/$PLUGIN" ]; then
    echo "Ошибка: плагин '$PLUGIN' не найден в $PLUGINS_DIR"
    exit 1
fi

if [ "$1" = "all" ]; then
    PROJECTS=()
    for dir in /home/c91469/*/www/plugins; do
        if [ -d "$dir" ]; then
            name=$(basename $(dirname $(dirname $dir)))
            PROJECTS+=("$name")
        fi
    done
    # bajto.ru
    PROJECTS+=("bajto.ru")
    set -- "${PROJECTS[@]}"
fi

for PROJECT in "$@"; do
    if [ "$PROJECT" = "bajto.ru" ]; then
        echo -n "[*] $PLUGIN → bajto.ru (сервер 62.113.103.68)... "
        if ssh -i ~/.ssh/id_ed25519 -o ConnectTimeout=5 root@62.113.103.68 "test -d /var/www/bajto/plugins" 2>/dev/null; then
            rsync -a --delete --exclude=.git -e "ssh -i ~/.ssh/id_ed25519" \
                "$PLUGINS_DIR/$PLUGIN/" root@62.113.103.68:/var/www/bajto/plugins/$PLUGIN/ 2>/dev/null && echo "OK" || echo "FAIL"
        else
            echo "SKIP (сервер недоступен)"
        fi
        continue
    fi

    TARGET="/home/c91469/$PROJECT/www/plugins/$PLUGIN"
    echo -n "[*] $PLUGIN → $PROJECT... "
    if [ -d "$TARGET" ]; then
        rsync -a --delete --exclude=.git "$PLUGINS_DIR/$PLUGIN/" "$TARGET/" 2>/dev/null && echo "OK" || echo "FAIL"
    else
        echo "SKIP (нет plugins/)"
    fi
done

echo "Готово."
