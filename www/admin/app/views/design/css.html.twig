{% extends base_template %}

{% block title %}Редактор CSS-стилей{% endblock %}
{% block page_title %}🎨 Редактор CSS-стилей{% endblock %}

{% block content %}
<div class="max-w-5xl mx-auto">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <div class="p-4 md:p-6 border-b border-gray-200">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                <div>
                    <h2 class="text-lg font-semibold text-gray-800 mb-1">Глобальные CSS-стили</h2>
                    <p class="text-sm text-gray-500">
                        Редактирование файла <code class="bg-gray-100 px-1.5 py-0.5 rounded text-xs">{{ css_url }}</code>.
                        Стили применяются на всех страницах сайта.
                        <a href="/" target="_blank" class="text-blue-600 hover:text-blue-800 underline ml-1">
                            Открыть сайт →
                        </a>
                    </p>
                </div>
            </div>
        </div>

        <form method="POST" action="{{ admin_url('design/css/save') }}" class="p-4 md:p-6">
            <div class="mb-4">
                <textarea id="css-editor"
                          name="css"
                          class="w-full font-mono text-sm leading-relaxed p-4 border border-gray-300 rounded-lg focus:border-blue-500 focus:ring-1 focus:ring-blue-500 resize-y"
                          rows="32"
                          spellcheck="false"
                          placeholder="/* Введите CSS-стили */&#10;&#10;.my-class {&#10;    color: #8B5CF6;&#10;}">{{ css_content }}</textarea>

            {% if app.request.get('cache_cleared') %}
                <div class="mt-3 p-3 bg-green-50 border border-green-200 text-green-700 rounded-lg text-sm flex items-center space-x-2">
                    <i class="fas fa-check-circle"></i>
                    <span>Кэш CSS очищен. Браузеры загрузят новую версию стилей.</span>
                </div>
            {% endif %}
            </div>

            <div class="flex items-center justify-between">
                <div>
                    <span class="text-xs text-gray-400">
                        <i class="fas fa-info-circle mr-1"></i>
                        Файл: <code class="bg-gray-100 px-1 rounded text-xs">{{ css_url }}</code>
                    </span>
                </div>
                <div class="flex items-center space-x-3">
                    <a href="{{ admin_url('design/css/clear-cache') }}"
                       class="px-4 py-2 bg-amber-50 text-amber-700 border border-amber-200 rounded-md hover:bg-amber-100 transition flex items-center space-x-2 text-sm"
                       onclick="return confirm('Сбросить кэш CSS? Новая версия файла будет отправлена браузерам.')">
                        <i class="fas fa-broom"></i><span>Очистить кэш браузера</span>
                    </a>
                    <button type="submit"
                            class="px-6 py-2 bg-green-600 text-white rounded-md hover:bg-green-700 transition flex items-center space-x-2">
                        <i class="fas fa-save"></i><span>Сохранить стили</span>
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const editor = document.getElementById('css-editor');
    if (editor) {
        // Tab → 4 пробела
        editor.addEventListener('keydown', function(e) {
            if (e.key === 'Tab') {
                e.preventDefault();
                const start = this.selectionStart;
                const end = this.selectionEnd;
                this.value = this.value.substring(0, start) + '    ' + this.value.substring(end);
                this.selectionStart = this.selectionEnd = start + 4;
            }
        });

        // Ctrl+S / Cmd+S → сабмит формы
        editor.addEventListener('keydown', function(e) {
            if ((e.ctrlKey || e.metaKey) && e.key === 's') {
                e.preventDefault();
                this.form.submit();
            }
        });
    }
});
</script>
{% endblock %}
