{# twig #}
{% extends base_template %}

{% block page_title %}{{ title }}{% endblock %}

{% block content %}
<div class="max-w-6xl mx-auto">
    <!-- Заголовок -->
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">{{ title }}</h1>
            <p class="text-sm text-gray-500 mt-1">Плагин: {{ plugin_name }} &mdash; {{ file_path }}</p>
        </div>
        <div class="flex items-center space-x-3">
            <a href="{{ admin_url('plugins/' ~ plugin_name ~ '?tab=templates') }}" 
               class="inline-flex items-center space-x-2 px-4 py-2 border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 transition">
                <i class="fas fa-arrow-left"></i>
                <span>Назад к шаблонам</span>
            </a>
        </div>
    </div>

    <!-- Flash -->
    {% if flash %}
    <div class="mb-4 px-4 py-3 rounded-md {% if flash.type == 'success' %}bg-green-50 border border-green-200 text-green-700{% else %}bg-red-50 border border-red-200 text-red-700{% endif %}">
        {{ flash.message }}
    </div>
    {% endif %}

    <!-- Форма редактирования -->
    <div class="bg-white rounded-lg shadow-sm border">
        <div class="px-6 py-4 border-b">
            <h2 class="text-lg font-semibold">{{ file_name }}</h2>
        </div>
        <div class="p-6">
            <form method="post" class="space-y-6">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        Содержимое шаблона
                    </label>
                    <textarea name="content" id="templateContent" rows="25"
                              class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 font-mono text-sm"
                              placeholder="Введите Twig код...">{{ content }}</textarea>
                </div>

                <!-- Статистика -->
                <div class="flex items-center justify-between text-sm text-gray-500">
                    <span id="lineCount">Строк: {{ content|split('\n')|length }}</span>
                    <span id="charCount">Символов: {{ content|length }}</span>
                </div>

                <!-- Подсказка -->
                <div class="p-4 bg-blue-50 border border-blue-200 rounded-lg">
                    <div class="flex items-start space-x-3">
                        <i class="fas fa-info-circle text-blue-500 mt-1"></i>
                        <div class="text-sm text-blue-700">
                            <strong>Twig-шаблон плагина.</strong>
                            Доступны все стандартные функции и фильтры Twig, а также функции плагина.
                        </div>
                    </div>
                </div>

                <!-- Кнопки -->
                <div class="flex items-center justify-end space-x-4 pt-6 border-t">
                    <a href="{{ admin_url('plugins/' ~ plugin_name ~ '?tab=templates') }}" 
                       class="px-6 py-2 border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 transition">
                        Отмена
                    </a>
                    <button type="submit" 
                            class="px-6 py-2 bg-green-600 text-white rounded-md hover:bg-green-700 transition flex items-center space-x-2">
                        <i class="fas fa-save"></i>
                        <span>Сохранить</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const textarea = document.getElementById('templateContent');
    if (textarea) {
        textarea.addEventListener('input', function() {
            var lines = this.value.split('\n').length;
            document.getElementById('lineCount').textContent = 'Строк: ' + lines;
            document.getElementById('charCount').textContent = 'Символов: ' + this.value.length;
        });
    }
    // Ctrl+S
    document.addEventListener('keydown', function(e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 's') {
            e.preventDefault();
            document.querySelector('button[type="submit"]').click();
        }
    });
});
</script>
{% endblock %}
