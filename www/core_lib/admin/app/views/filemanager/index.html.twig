{# admin/app/views/filemanager/index.html.twig — v2: таблица/сетка, per-page, пагинация #}
{% extends "base.html.twig" %}

{% block title %}Файловый менеджер{% endblock %}

{% block page_title %}Файловый менеджер{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto">
    <!-- Заголовок и кнопки -->
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Файловый менеджер</h1>
            <p class="text-sm text-gray-500 mt-1">Управление файлами и изображениями сайта</p>
        </div>
        <div class="flex items-center space-x-3">
            <button onclick="showUploadModal()" 
                    class="inline-flex items-center space-x-2 px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition">
                <i class="fas fa-upload"></i>
                <span>Загрузить файл</span>
            </button>
            <button onclick="createFolder()" 
                    class="inline-flex items-center space-x-2 px-4 py-2 border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 transition">
                <i class="fas fa-folder-plus"></i>
                <span>Создать папку</span>
            </button>
        </div>
    </div>

    <!-- Хлебные крошки -->
    <div class="bg-white rounded-lg shadow-sm border p-4 mb-6">
        <nav class="flex" aria-label="Breadcrumb">
            <ol class="flex items-center space-x-2">
                <li>
                    <a href="/admin/filemanager" class="text-gray-500 hover:text-gray-700">
                        <i class="fas fa-home"></i>
                    </a>
                </li>
                {% for crumb in breadcrumbs %}
                    <li class="flex items-center">
                        <span class="mx-2 text-gray-400">/</span>
                        <a href="/admin/filemanager?path={{ crumb.path|url_encode }}" 
                           class="text-gray-500 hover:text-gray-700 {{ loop.last ? 'font-medium text-gray-900' : '' }}">
                            {{ crumb.name }}
                        </a>
                    </li>
                {% endfor %}
            </ol>
        </nav>
    </div>

    <!-- Панель управления: переключатель вида + per-page + счётчик -->
    <div class="bg-white rounded-lg shadow-sm border p-4 mb-6">
        <div class="flex items-center justify-between flex-wrap gap-4">
            <!-- Переключатель вида -->
            <div class="flex items-center space-x-2">
                <span class="text-sm text-gray-500 mr-1">Вид:</span>
                <button onclick="setViewMode('grid')" id="btn-grid" 
                        class="p-2 rounded-md border border-gray-300 text-gray-600 hover:bg-gray-100 transition"
                        title="Сетка">
                    <i class="fas fa-th-large"></i>
                </button>
                <button onclick="setViewMode('table')" id="btn-table"
                        class="p-2 rounded-md border border-gray-300 text-gray-600 hover:bg-gray-100 transition"
                        title="Таблица">
                    <i class="fas fa-list"></i>
                </button>
            </div>

            <!-- Кол-во колонок в сетке -->
            <div class="flex items-center space-x-2">
                <span class="text-sm text-gray-500">Колонок:</span>
                <select id="colsSelect" onchange="changeCols(this.value)" 
                        class="border border-gray-300 rounded-md text-sm px-3 py-1.5 bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                    <option value="2" {{ cols == 2 ? 'selected' : '' }}>2</option>
                    <option value="3" {{ cols == 3 ? 'selected' : '' }}>3</option>
                    <option value="4" {{ cols == 4 ? 'selected' : '' }}>4</option>
                    <option value="6" {{ cols == 6 ? 'selected' : '' }}>6</option>
                </select>
            </div>

            <!-- Селектор кол-ва записей -->
            <div class="flex items-center space-x-2">
                <span class="text-sm text-gray-500">Показывать:</span>
                <select id="perPageSelect" onchange="changePerPage(this.value)" 
                        class="border border-gray-300 rounded-md text-sm px-3 py-1.5 bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                    <option value="10" {{ pagination.per_page == 10 ? 'selected' : '' }}>10</option>
                    <option value="20" {{ pagination.per_page == 20 ? 'selected' : '' }}>20</option>
                    <option value="50" {{ pagination.per_page == 50 ? 'selected' : '' }}>50</option>
                </select>
            </div>

            <!-- Счётчик -->
            <div class="text-sm text-gray-500">
                {% if pagination.total > 0 %}
                    {{ pagination.from }}–{{ pagination.to }} из {{ pagination.total }}
                {% else %}
                    Нет файлов
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Контент: сетка или таблица -->
    <div class="bg-white rounded-lg shadow-sm border">
        {% if items is empty %}
            <div class="p-12 text-center">
                <i class="fas fa-folder-open text-gray-300 text-5xl mb-4"></i>
                <h3 class="text-lg font-medium text-gray-900 mb-2">Папка пуста</h3>
                <p class="text-gray-500 mb-4">Загрузите файлы или создайте новую папку</p>
                <button onclick="showUploadModal()" 
                        class="inline-flex items-center space-x-2 px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition">
                    <i class="fas fa-upload"></i>
                    <span>Загрузить первый файл</span>
                </button>
            </div>
        {% else %}
            {# ===== Режим СЕТКИ ===== #}
            <div id="view-grid" class="hidden">
                {% set grid_class = cols == 2 ? 'grid-cols-1 sm:grid-cols-2' : (cols == 3 ? 'grid-cols-2 sm:grid-cols-3' : (cols == 4 ? 'grid-cols-2 sm:grid-cols-3 md:grid-cols-4' : 'grid-cols-2 md:grid-cols-4 lg:grid-cols-6')) %}
                {% set thumb_size = cols == 2 ? 400 : (cols == 3 ? 320 : (cols == 4 ? 240 : 160)) %}
                {% set thumb_class = cols == 2 ? 'mx-auto w-80 h-80 object-cover rounded' : (cols == 3 ? 'mx-auto w-64 h-64 object-cover rounded' : (cols == 4 ? 'mx-auto w-48 h-48 object-cover rounded' : 'mx-auto w-32 h-32 object-cover rounded')) %}
                <div class="grid {{ grid_class }} gap-4 p-6">
                    {% for item in items %}
                        <div class="file-item group relative bg-gray-50 rounded-lg p-4 hover:bg-gray-100 transition cursor-pointer"
                             data-name="{{ item.name }}"
                             data-path="{{ item.path }}"
                             data-type="{{ item.is_dir ? 'folder' : 'file' }}">
                            
                            {% if item.is_dir %}
                                <div class="text-center">
                                    <i class="fas fa-folder text-yellow-500 text-4xl mb-2"></i>
                                    <div class="file-name text-sm font-medium text-gray-900 truncate" title="{{ item.name }}">
                                        {{ item.name }}
                                    </div>
                                    <div class="text-xs text-gray-500 mt-1">Папка</div>
                                </div>
                            {% else %}
                                <div class="text-center">
                                    {% if item.is_image %}
                                        <div class="relative mb-2">
                                            <img src="/admin/filemanager/thumb?path={{ item.path|url_encode }}&amp;w={{ thumb_size }}&amp;h={{ thumb_size }}&amp;v={{ item.modified }}" 
                                                 alt="{{ item.name }}"
                                                 loading="lazy"
                                                 class="{{ thumb_class }}">
                                            <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-10 transition rounded"></div>
                                        </div>
                                    {% else %}
                                        <i class="fas fa-file text-blue-500 text-4xl mb-2"></i>
                                    {% endif %}
                                    <div class="file-name text-sm font-medium text-gray-900 truncate" title="{{ item.name }}">
                                        {{ item.name }}
                                    </div>
                                    <div class="text-xs text-gray-500 mt-1">{{ item.size }}</div>
                                </div>
                            {% endif %}
                            
                            <!-- Контекстное меню -->
                            <div class="absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                <div class="flex space-x-1">
                                    <button onclick="event.stopPropagation(); renameItem('{{ item.path }}', '{{ item.is_dir ? 'folder' : 'file' }}', '{{ item.name }}')" 
                                            class="p-1 bg-white rounded shadow-sm hover:bg-blue-50 transition"
                                            title="Переименовать">
                                        <i class="fas fa-edit text-xs text-blue-600"></i>
                                    </button>
                                    {% if not item.is_dir %}
                                        <button onclick="copyFileUrl('{{ item.path }}')" 
                                                class="p-1 bg-white rounded shadow-sm hover:bg-gray-50 transition"
                                                title="Копировать ссылку">
                                            <i class="fas fa-link text-xs text-gray-600"></i>
                                        </button>
                                    {% endif %}
                                    <button onclick="deleteItem('{{ item.path }}', '{{ item.is_dir ? 'folder' : 'file' }}')" 
                                            class="p-1 bg-white rounded shadow-sm hover:bg-red-50 transition"
                                            title="Удалить">
                                        <i class="fas fa-trash text-xs text-red-600"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>

            {# ===== Режим ТАБЛИЦЫ ===== #}
            <div id="view-table" class="hidden">
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead class="bg-gray-50 border-b">
                            <tr>
                                <th class="text-left py-3 px-4 text-xs font-medium text-gray-500 uppercase tracking-wider">Имя</th>
                                <th class="text-left py-3 px-4 text-xs font-medium text-gray-500 uppercase tracking-wider hidden sm:table-cell">Размер</th>
                                <th class="text-left py-3 px-4 text-xs font-medium text-gray-500 uppercase tracking-wider hidden md:table-cell">Изменён</th>
                                <th class="text-right py-3 px-4 text-xs font-medium text-gray-500 uppercase tracking-wider">Действия</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            {% for item in items %}
                                <tr class="file-item-table hover:bg-gray-50 transition cursor-pointer"
                                    data-name="{{ item.name }}"
                                    data-path="{{ item.path }}"
                                    data-type="{{ item.is_dir ? 'folder' : 'file' }}">
                                    
                                    <!-- Имя -->
                                    <td class="py-3 px-4">
                                        <div class="flex items-center space-x-3">
                                            {% if item.is_dir %}
                                                <i class="fas fa-folder text-yellow-500 text-lg"></i>
                                            {% elseif item.is_image %}
                                                <img src="/admin/filemanager/thumb?path={{ item.path|url_encode }}&amp;w=64&amp;h=64&amp;v={{ item.modified }}" 
                                                     alt="" loading="lazy" class="w-8 h-8 object-cover rounded">
                                            {% else %}
                                                <i class="fas fa-file text-blue-500 text-lg"></i>
                                            {% endif %}
                                            <span class="text-sm font-medium text-gray-900 truncate max-w-[200px] sm:max-w-xs" 
                                                  title="{{ item.name }}">{{ item.name }}</span>
                                        </div>
                                    </td>
                                    
                                    <!-- Размер -->
                                    <td class="py-3 px-4 text-sm text-gray-500 hidden sm:table-cell">
                                        {{ item.is_dir ? '—' : item.size }}
                                    </td>
                                    
                                    <!-- Изменён -->
                                    <td class="py-3 px-4 text-sm text-gray-500 hidden md:table-cell">
                                        {{ item.modified_formatted }}
                                    </td>
                                    
                                    <!-- Действия -->
                                    <td class="py-3 px-4 text-right">
                                        <div class="flex items-center justify-end space-x-1">
                                            <button onclick="event.stopPropagation(); renameItem('{{ item.path }}', '{{ item.is_dir ? 'folder' : 'file' }}', '{{ item.name }}')" 
                                                    class="p-1.5 rounded hover:bg-blue-50 transition"
                                                    title="Переименовать">
                                                <i class="fas fa-edit text-sm text-blue-600"></i>
                                            </button>
                                            {% if not item.is_dir %}
                                                <button onclick="event.stopPropagation(); copyFileUrl('{{ item.path }}')" 
                                                        class="p-1.5 rounded hover:bg-gray-100 transition"
                                                        title="Копировать ссылку">
                                                    <i class="fas fa-link text-sm text-gray-600"></i>
                                                </button>
                                            {% endif %}
                                            <button onclick="event.stopPropagation(); deleteItem('{{ item.path }}', '{{ item.is_dir ? 'folder' : 'file' }}')" 
                                                    class="p-1.5 rounded hover:bg-red-50 transition"
                                                    title="Удалить">
                                                <i class="fas fa-trash text-sm text-red-600"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}
    </div>

    {# ===== ПАГИНАЦИЯ ===== #}
    {% if pagination.total_pages > 1 %}
    <div class="mt-6 flex items-center justify-between">
        <div class="text-sm text-gray-500">
            Страница {{ pagination.page }} из {{ pagination.total_pages }}
        </div>
        <nav class="flex items-center space-x-1">
            {# Первая #}
            {% if pagination.page > 1 %}
                <a href="?path={{ currentPath|url_encode }}&page=1&per_page={{ pagination.per_page }}&cols={{ cols }}" 
                   class="px-3 py-2 text-sm border border-gray-300 rounded-md text-gray-500 hover:bg-gray-50 transition"
                   title="Первая">
                    <i class="fas fa-angle-double-left"></i>
                </a>
                <a href="?path={{ currentPath|url_encode }}&page={{ pagination.page - 1 }}&per_page={{ pagination.per_page }}&cols={{ cols }}" 
                   class="px-3 py-2 text-sm border border-gray-300 rounded-md text-gray-500 hover:bg-gray-50 transition"
                   title="Предыдущая">
                    <i class="fas fa-angle-left"></i>
                </a>
            {% else %}
                <span class="px-3 py-2 text-sm border border-gray-200 rounded-md text-gray-300 cursor-not-allowed">
                    <i class="fas fa-angle-double-left"></i>
                </span>
                <span class="px-3 py-2 text-sm border border-gray-200 rounded-md text-gray-300 cursor-not-allowed">
                    <i class="fas fa-angle-left"></i>
                </span>
            {% endif %}

            {# Номера страниц (показываем окно вокруг текущей) #}
            {% set startPage = max(1, pagination.page - 2) %}
            {% set endPage = min(pagination.total_pages, pagination.page + 2) %}
            
            {% if startPage > 1 %}
                <span class="px-2 text-gray-400">…</span>
            {% endif %}
            
            {% for p in range(startPage, endPage) %}
                {% if p == pagination.page %}
                    <span class="px-3 py-2 text-sm bg-blue-600 text-white rounded-md font-medium">{{ p }}</span>
                {% else %}
                    <a href="?path={{ currentPath|url_encode }}&page={{ p }}&per_page={{ pagination.per_page }}&cols={{ cols }}" 
                       class="px-3 py-2 text-sm border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50 transition">
                        {{ p }}
                    </a>
                {% endif %}
            {% endfor %}
            
            {% if endPage < pagination.total_pages %}
                <span class="px-2 text-gray-400">…</span>
            {% endif %}

            {# Последняя #}
            {% if pagination.page < pagination.total_pages %}
                <a href="?path={{ currentPath|url_encode }}&page={{ pagination.page + 1 }}&per_page={{ pagination.per_page }}&cols={{ cols }}" 
                   class="px-3 py-2 text-sm border border-gray-300 rounded-md text-gray-500 hover:bg-gray-50 transition"
                   title="Следующая">
                    <i class="fas fa-angle-right"></i>
                </a>
                <a href="?path={{ currentPath|url_encode }}&page={{ pagination.total_pages }}&per_page={{ pagination.per_page }}&cols={{ cols }}" 
                   class="px-3 py-2 text-sm border border-gray-300 rounded-md text-gray-500 hover:bg-gray-50 transition"
                   title="Последняя">
                    <i class="fas fa-angle-double-right"></i>
                </a>
            {% else %}
                <span class="px-3 py-2 text-sm border border-gray-200 rounded-md text-gray-300 cursor-not-allowed">
                    <i class="fas fa-angle-right"></i>
                </span>
                <span class="px-3 py-2 text-sm border border-gray-200 rounded-md text-gray-300 cursor-not-allowed">
                    <i class="fas fa-angle-double-right"></i>
                </span>
            {% endif %}
        </nav>
    </div>
    {% endif %}
</div>

<!-- Модальное окно загрузки -->
<div id="uploadModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-md mx-4">
        <div class="p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Загрузить файл</h3>
            <form id="uploadForm" enctype="multipart/form-data">
                <input type="hidden" name="path" value="{{ currentPath }}">
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Выберите файл</label>
                    <input type="file" name="file" 
                           class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100"
                           required>
                    <p class="text-xs text-gray-500 mt-1">Максимальный размер: 5MB</p>
                </div>
                <div class="flex justify-end space-x-3">
                    <button type="button" onclick="hideUploadModal()"
                            class="px-4 py-2 border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 transition">
                        Отмена
                    </button>
                    <button type="submit" 
                            class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition flex items-center space-x-2">
                        <i class="fas fa-upload"></i>
                        <span>Загрузить</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
// === ИНИЦИАЛИЗАЦИЯ: режим отображения ===
(function() {
    const savedMode = localStorage.getItem('filemanager_view_mode') || 'grid';
    applyViewMode(savedMode);
})();

function setViewMode(mode) {
    localStorage.setItem('filemanager_view_mode', mode);
    applyViewMode(mode);
}

function applyViewMode(mode) {
    const gridView = document.getElementById('view-grid');
    const tableView = document.getElementById('view-table');
    const btnGrid = document.getElementById('btn-grid');
    const btnTable = document.getElementById('btn-table');
    
    if (!gridView || !tableView) return;
    
    if (mode === 'table') {
        gridView.classList.add('hidden');
        tableView.classList.remove('hidden');
        btnGrid.classList.remove('bg-blue-100', 'text-blue-700', 'border-blue-300');
        btnTable.classList.add('bg-blue-100', 'text-blue-700', 'border-blue-300');
        // Привязываем клики для таблицы
        bindTableClicks();
    } else {
        tableView.classList.add('hidden');
        gridView.classList.remove('hidden');
        btnTable.classList.remove('bg-blue-100', 'text-blue-700', 'border-blue-300');
        btnGrid.classList.add('bg-blue-100', 'text-blue-700', 'border-blue-300');
        // Привязываем клики для сетки
        bindGridClicks();
    }
}

// === НАВИГАЦИЯ: сетка ===
function bindGridClicks() {
    const fileItems = document.querySelectorAll('#view-grid .file-item');
    fileItems.forEach(item => {
        // Убираем старые обработчики через клонирование
        const clone = item.cloneNode(true);
        item.parentNode.replaceChild(clone, item);
        
        clone.addEventListener('click', function(e) {
            // Игнорируем клики по кнопкам действий
            if (e.target.closest('button') || e.target.closest('.absolute')) return;

            const path = this.dataset.path;
            const type = this.dataset.type;

            // Подсветка
            document.querySelectorAll('#view-grid .file-item').forEach(i => i.classList.remove('ring-2', 'ring-blue-500'));
            this.classList.add('ring-2', 'ring-blue-500');

            if (type === 'folder') {
                window.location.href = buildUrl({ path: path, page: 1 });
            } else {
                showFileInfo(path);
            }
        });
    });
}

// === НАВИГАЦИЯ: таблица ===
function bindTableClicks() {
    const rows = document.querySelectorAll('#view-table .file-item-table');
    rows.forEach(row => {
        // Убираем старые обработчики через клонирование
        const clone = row.cloneNode(true);
        row.parentNode.replaceChild(clone, row);

        clone.addEventListener('click', function(e) {
            if (e.target.closest('button')) return;

            const path = this.dataset.path;
            const type = this.dataset.type;

            document.querySelectorAll('#view-table .file-item-table').forEach(r => r.classList.remove('bg-blue-50'));
            this.classList.add('bg-blue-50');

            if (type === 'folder') {
                window.location.href = buildUrl({ path: path, page: 1 });
            } else {
                showFileInfo(path);
            }
        });
    });
}

// === ПАГИНАЦИЯ: смена per_page ===
function changeCols(cols) {
    localStorage.setItem('filemanager_cols', cols);
    window.location.href = buildUrl({ cols: cols });
}

function changePerPage(perPage) {
    window.location.href = buildUrl({ per_page: perPage, page: 1 });
}

// === Вспомогательная: построение URL с параметрами ===
function buildUrl(overrides) {
    const params = new URLSearchParams(window.location.search);
    const currentPath = '{{ currentPath }}';
    
    if (currentPath) params.set('path', currentPath);
    if (overrides.path !== undefined) {
        if (overrides.path) params.set('path', overrides.path);
        else params.delete('path');
    }
    if (overrides.page !== undefined) params.set('page', overrides.page);
    if (overrides.per_page !== undefined) params.set('per_page', overrides.per_page);
    if (overrides.cols !== undefined) params.set('cols', overrides.cols);
    
    return '/admin/filemanager?' + params.toString();
}

// === API запросы ===
async function apiRequest(url, options = {}) {
    try {
        const response = await fetch(url, {
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            ...options
        });
        if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
        const responseText = await response.text();
        try {
            return JSON.parse(responseText);
        } catch (jsonError) {
            console.error('JSON parse error:', jsonError);
            console.error('Response text:', responseText);
            throw new Error('Неверный формат ответа от сервера');
        }
    } catch (error) {
        console.error('API request failed:', error);
        throw error;
    }
}

// === Модальное окно загрузки ===
function showUploadModal() {
    document.getElementById('uploadModal').classList.remove('hidden');
    document.getElementById('uploadModal').classList.add('flex');
}
function hideUploadModal() {
    document.getElementById('uploadModal').classList.add('hidden');
    document.getElementById('uploadModal').classList.remove('flex');
}

// === Загрузка файла ===
document.getElementById('uploadForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const fileInput = this.querySelector('input[type="file"]');
    const originalFileName = fileInput.files[0]?.name;
    if (originalFileName) {
        const safeName = transliterate(originalFileName);
        console.log('Original:', originalFileName, 'Safe:', safeName);
    }
    const formData = new FormData(this);
    const submitBtn = this.querySelector('button[type="submit"]');
    const originalText = submitBtn.innerHTML;
    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i><span>Загрузка...</span>';
    submitBtn.disabled = true;
    try {
        const response = await fetch('/admin/filemanager/upload', { method: 'POST', body: formData });
        if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
        const responseText = await response.text();
        let data;
        try { data = JSON.parse(responseText); }
        catch (jsonError) {
            console.error('JSON parse error:', jsonError);
            console.error('Response text:', responseText);
            throw new Error('Неверный формат ответа от сервера');
        }
        if (data.success) {
            hideUploadModal();
            showNotification(data.message, 'success');
            setTimeout(() => location.reload(), 1000);
        } else {
            showNotification(data.message, 'error');
        }
    } catch (error) {
        console.error('Upload error:', error);
        showNotification('Ошибка загрузки: ' + error.message, 'error');
    } finally {
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
    }
});

// === Копирование ссылки ===
function copyFileUrl(filePath) {
    const url = '{{ storageUrl }}' + filePath;
    navigator.clipboard.writeText(url).then(() => {
        showNotification('Ссылка скопирована в буфер обмена', 'success');
    }).catch(() => {
        const textArea = document.createElement('textarea');
        textArea.value = url;
        document.body.appendChild(textArea);
        textArea.select();
        document.execCommand('copy');
        document.body.removeChild(textArea);
        showNotification('Ссылка скопирована', 'success');
    });
}

// === Удаление ===
async function deleteItem(path, type) {
    if (!confirm(`Вы уверены, что хотите удалить этот ${type === 'folder' ? 'папку' : 'файл'}?`)) return;
    
    const clickedBtn = event && event.target ? event.target.closest('button') : null;
    let originalHtml = '';
    if (clickedBtn) {
        originalHtml = clickedBtn.innerHTML;
        clickedBtn.innerHTML = '<i class="fas fa-spinner fa-spin text-xs"></i>';
        clickedBtn.disabled = true;
    }
    
    try {
        const data = await apiRequest('/admin/filemanager/delete', {
            method: 'POST',
            body: 'path=' + encodeURIComponent(path) + '&type=' + type
        });
        if (data.success) {
            showNotification(data.message, 'success');
            setTimeout(() => location.reload(), 1000);
        } else {
            showNotification(data.message, 'error');
            if (clickedBtn) { clickedBtn.innerHTML = originalHtml; clickedBtn.disabled = false; }
        }
    } catch (error) {
        console.error('Delete error:', error);
        showNotification('Ошибка удаления: ' + error.message, 'error');
        if (clickedBtn) { clickedBtn.innerHTML = originalHtml; clickedBtn.disabled = false; }
    }
}

// === Создание папки ===
async function createFolder() {
    const folderName = prompt('Введите название папки:');
    if (!folderName) return;
    if (!/^[a-zA-Z0-9_-]+$/.test(folderName)) {
        alert('Название папки может содержать только буквы, цифры, дефисы и подчеркивания');
        return;
    }
    const currentPath = '{{ currentPath }}';
    try {
        const data = await apiRequest('/admin/filemanager/create-folder', {
            method: 'POST',
            body: 'path=' + encodeURIComponent(currentPath) + '&name=' + encodeURIComponent(folderName)
        });
        if (data.success) {
            showNotification(data.message, 'success');
            setTimeout(() => location.reload(), 1000);
        } else {
            showNotification(data.message, 'error');
        }
    } catch (error) {
        console.error('Create folder error:', error);
        showNotification('Ошибка создания папки: ' + error.message, 'error');
    }
}

// === Информация о файле ===
async function showFileInfo(filePath) {
    try {
        const data = await apiRequest('/admin/filemanager/file-info?path=' + encodeURIComponent(filePath));
        if (data.success) {
            const file = data.data;
            let infoHtml = `
                <div class="mb-4">
                    <h4 class="font-semibold text-gray-900">${file.name}</h4>
                    <p class="text-sm text-gray-500">${file.path}</p>
                </div>
                <div class="space-y-2 text-sm">
                    <div class="flex justify-between"><span>Размер:</span><span class="font-medium">${file.size}</span></div>
                    <div class="flex justify-between"><span>Изменен:</span><span class="font-medium">${file.modified}</span></div>
            `;
            if (file.is_image && file.dimensions) {
                infoHtml += `<div class="flex justify-between"><span>Размеры:</span><span class="font-medium">${file.dimensions}</span></div>`;
            }
            infoHtml += `
                </div>
                <div class="mt-4 pt-4 border-t">
                    <button onclick="copyFileUrl('${file.path}')" 
                            class="w-full inline-flex justify-center items-center space-x-2 px-4 py-2 border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 transition">
                        <i class="fas fa-link"></i><span>Копировать ссылку</span>
                    </button>
                </div>`;
            showModal('Информация о файле', infoHtml);
        } else {
            showNotification(data.message, 'error');
        }
    } catch (error) {
        console.error('File info error:', error);
        showNotification('Ошибка загрузки информации: ' + error.message, 'error');
    }
}

// === Модальное окно ===
function showModal(title, content) {
    closeModal();
    const modalHtml = `
        <div id="infoModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
            <div class="bg-white rounded-lg shadow-xl w-full max-w-md mx-4">
                <div class="p-6">
                    <h3 class="text-lg font-semibold text-gray-900 mb-4">${title}</h3>
                    ${content}
                    <div class="mt-6 flex justify-end">
                        <button onclick="closeModal()" class="px-4 py-2 border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 transition">Закрыть</button>
                    </div>
                </div>
            </div>
        </div>`;
    const modal = document.createElement('div');
    modal.innerHTML = modalHtml;
    document.body.appendChild(modal);
}
function closeModal() {
    const modal = document.getElementById('infoModal');
    if (modal) modal.remove();
}

// === Уведомления ===
function showNotification(message, type = 'info') {
    const notification = document.createElement('div');
    const bgColor = type === 'success' ? 'bg-green-500' : type === 'error' ? 'bg-red-500' : 'bg-blue-500';
    notification.className = `fixed top-4 right-4 ${bgColor} text-white px-6 py-3 rounded-lg shadow-lg z-50 transform transition-transform duration-300 translate-x-full`;
    notification.innerHTML = `
        <div class="flex items-center space-x-3">
            <i class="fas ${type === 'success' ? 'fa-check' : type === 'error' ? 'fa-exclamation-triangle' : 'fa-info'}"></i>
            <span>${message}</span>
        </div>`;
    document.body.appendChild(notification);
    setTimeout(() => { notification.classList.remove('translate-x-full'); }, 100);
    setTimeout(() => {
        notification.classList.add('translate-x-full');
        setTimeout(() => { if (notification.parentNode) notification.parentNode.removeChild(notification); }, 300);
    }, 4000);
}

// === Закрытие по клику вне / ESC ===
document.addEventListener('click', function(e) {
    if (e.target.id === 'uploadModal') hideUploadModal();
    if (e.target.id === 'infoModal') closeModal();
});
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') { hideUploadModal(); closeModal(); }
});
document.addEventListener('click', function(e) {
    if (e.target.closest('.bg-white.rounded-lg')) e.stopPropagation();
});

// === Переименование ===
async function renameItem(path, type, currentName) {
    const suggestedName = transliterate(currentName);
    const newName = prompt(`Введите новое название для ${type === 'folder' ? 'папки' : 'файла'}:`, suggestedName);
    if (!newName || newName === currentName) return;
    if (!/^[a-zA-Z0-9_\-\.]+$/.test(newName)) {
        alert('Название может содержать только латинские буквы, цифры, точки, дефисы и подчеркивания');
        return;
    }
    try {
        const data = await apiRequest('/admin/filemanager/rename', {
            method: 'POST',
            body: 'path=' + encodeURIComponent(path) + '&new_name=' + encodeURIComponent(newName) + '&type=' + type
        });
        if (data.success) {
            showNotification(data.message, 'success');
            setTimeout(() => location.reload(), 1000);
        } else {
            showNotification(data.message, 'error');
        }
    } catch (error) {
        console.error('Rename error:', error);
        showNotification('Ошибка переименования: ' + error.message, 'error');
    }
}

// === Транслитерация (клиент) ===
function transliterate(text) {
    const cyrillicMap = {
        'а': 'a', 'б': 'b', 'в': 'v', 'г': 'g', 'д': 'd', 'е': 'e', 'ё': 'yo', 'ж': 'zh',
        'з': 'z', 'и': 'i', 'й': 'y', 'к': 'k', 'л': 'l', 'м': 'm', 'н': 'n', 'о': 'o',
        'п': 'p', 'р': 'r', 'с': 's', 'т': 't', 'у': 'u', 'ф': 'f', 'х': 'kh', 'ц': 'ts',
        'ч': 'ch', 'ш': 'sh', 'щ': 'shch', 'ъ': '', 'ы': 'y', 'ь': '', 'э': 'e', 'ю': 'yu',
        'я': 'ya', ' ': '_'
    };
    return text.toLowerCase().split('').map(char => {
        return cyrillicMap[char] || (/[a-zA-Z0-9_\-\.]/.test(char) ? char : '_');
    }).join('').replace(/_+/g, '_').replace(/^_|_$/g, '');
}

</script>

