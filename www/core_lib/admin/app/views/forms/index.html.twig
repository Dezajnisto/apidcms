{% extends "base.html.twig" %}

{% block content %}
<div class="container mx-auto px-4 py-6">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-gray-900">📋 Управление формами</h1>
        <button onclick="document.getElementById('createModal').classList.remove('hidden')"
                class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium transition">
            <i class="fas fa-plus mr-2"></i>Создать форму
        </button>
    </div>

    {# Flash messages #}
    {% if flash is defined and flash %}
        <div class="mb-4 p-4 rounded-lg {{ flash.type == 'success' ? 'bg-green-100 border border-green-200 text-green-800' : 'bg-red-100 border border-red-200 text-red-800' }}">
            {{ flash.message }}
        </div>
    {% endif %}

    {# Модальное окно создания формы #}
    <div id="createModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center">
        <div class="bg-white rounded-xl shadow-2xl max-w-lg w-full mx-4 p-6">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-lg font-bold">Новая форма</h2>
                <button onclick="document.getElementById('createModal').classList.add('hidden')"
                        class="text-gray-400 hover:text-gray-600">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>
            <form method="post" action="{{ admin_url('forms/create') }}">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Имя формы *</label>
                        <input type="text" name="new_name" required
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                               placeholder="Напр. callback, subscribe, feedback">
                        <p class="mt-1 text-xs text-gray-400">Уникальный идентификатор, только латиница</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Таблица для данных</label>
                        <input type="text" name="new_source_table" 
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                               placeholder="По умолчанию = имя формы">
                    </div>
                </div>
                <div class="flex justify-end space-x-3 mt-6">
                    <button type="button" onclick="document.getElementById('createModal').classList.add('hidden')"
                            class="px-4 py-2 text-gray-600 hover:text-gray-800 transition">Отмена</button>
                    <button type="submit"
                            class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg transition">Создать</button>
                </div>
            </form>
        </div>
    </div>

    {# Список форм #}
    {% if forms is empty %}
        <div class="bg-gray-50 rounded-xl p-12 text-center">
            <i class="fas fa-inbox text-4xl text-gray-300 mb-4"></i>
            <p class="text-gray-500">Нет ни одной формы. Создайте первую!</p>
        </div>
    {% else %}
        <div class="overflow-hidden bg-white rounded-xl shadow-sm border">
            <table class="w-full">
                <thead>
                    <tr class="bg-gray-50 border-b">
                        <th class="text-left px-4 py-3 text-sm font-medium text-gray-500">Имя</th>
                        <th class="text-left px-4 py-3 text-sm font-medium text-gray-500">Название</th>
                        <th class="text-left px-4 py-3 text-sm font-medium text-gray-500">Таблица</th>
                        <th class="text-center px-4 py-3 text-sm font-medium text-gray-500">Поля</th>
                        <th class="text-center px-4 py-3 text-sm font-medium text-gray-500">Шаблон</th>
                        <th class="text-center px-4 py-3 text-sm font-medium text-gray-500">Статус</th>
                        <th class="text-right px-4 py-3 text-sm font-medium text-gray-500">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    {% for form in forms %}
                    <tr class="border-b hover:bg-gray-50 transition">
                        <td class="px-4 py-3 font-medium text-gray-800">{{ form.name }}</td>
                        <td class="px-4 py-3 text-gray-600">{{ form.display_name }}</td>
                        <td class="px-4 py-3">
                            <span class="inline-block px-2 py-0.5 text-xs font-medium bg-purple-100 text-purple-700 rounded">
                                {{ form.source_table }}
                            </span>
                        </td>
                        <td class="px-4 py-3 text-center text-gray-600">{{ form.field_count }}</td>
                        <td class="px-4 py-3 text-center">
                            <span class="inline-block px-2 py-0.5 text-xs font-medium bg-gray-100 text-gray-600 rounded">
                                {{ form.template }}
                            </span>
                        </td>
                        <td class="px-4 py-3 text-center">
                            <a href="{{ admin_url('forms/toggle/' ~ form.name) }}" 
                               class="inline-block px-3 py-1 text-xs font-medium rounded-full transition
                               {{ form.status == 'active' 
                                   ? 'bg-green-100 text-green-700 hover:bg-green-200' 
                                   : 'bg-gray-100 text-gray-500 hover:bg-gray-200' }}">
                                {{ form.status == 'active' ? 'Активна' : 'Неактивна' }}
                            </a>
                        </td>
                        <td class="px-4 py-3 text-right space-x-2">
                            <a href="{{ admin_url('forms/edit/' ~ form.name) }}"
                               class="inline-block px-3 py-1.5 text-sm bg-blue-50 text-blue-600 hover:bg-blue-100 rounded-lg transition"
                               title="Редактировать">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a href="{{ admin_url('forms/delete/' ~ form.name) }}"
                               class="inline-block px-3 py-1.5 text-sm bg-red-50 text-red-600 hover:bg-red-100 rounded-lg transition"
                               title="Удалить"
                               onclick="return confirm('Удалить форму «{{ form.display_name }}»?')">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}
