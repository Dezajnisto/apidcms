{% extends base_template %}

{% block page_title %}Плагины{% endblock %}

{% block content %}
<div class="container mx-auto px-4 py-6 md:py-8">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6">
        <h1 class="text-xl md:text-2xl font-bold">🔌 Плагины</h1>
    </div>

    {% if flash %}
    <div class="mb-4 px-4 py-3 rounded-md text-sm {% if flash.type == 'success' %}bg-green-50 border border-green-200 text-green-700{% else %}bg-red-50 border border-red-200 text-red-700{% endif %}">
        {{ flash.message }}
    </div>
    {% endif %}

    {% if plugins is empty %}
    <div class="text-center py-12 md:py-16 text-gray-500">
        <div class="text-4xl md:text-5xl mb-4">🔌</div>
        <p class="text-lg md:text-xl">Плагины не найдены</p>
        <p class="mt-2 text-sm">Создайте директорию <code class="bg-gray-100 px-2 py-1 rounded">plugins/имя_плагина/</code></p>
    </div>
    {% else %}
    <div class="bg-white shadow rounded-lg overflow-hidden">
        <div class="overflow-x-auto">
            <table class="data-table w-full">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-3 text-left text-sm font-medium text-gray-500">Плагин</th>
                        <th class="px-4 py-3 text-left text-sm font-medium text-gray-500 hidden sm:table-cell">Версия</th>
                        <th class="px-4 py-3 text-left text-sm font-medium text-gray-500 hidden md:table-cell">Описание</th>
                        <th class="px-4 py-3 text-center text-sm font-medium text-gray-500">Статус</th>
                        <th class="px-4 py-3 text-right text-sm font-medium text-gray-500">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    {% for plugin in plugins %}
                    <tr class="border-t hover:bg-gray-50">
                        <td class="px-4 py-3 font-medium" data-label="Плагин">
                            <a href="{{ admin_url('plugins/' ~ plugin.name) }}" class="text-blue-600 hover:text-blue-800 hover:underline text-sm">
                                {{ plugin.name }}
                            </a>
                        </td>
                        <td class="px-4 py-3 text-sm text-gray-500 hidden sm:table-cell" data-label="Версия">v{{ plugin.version }}</td>
                        <td class="px-4 py-3 text-sm text-gray-600 hidden md:table-cell" data-label="Описание">{{ plugin.description }}</td>
                        <td class="px-4 py-3 text-center" data-label="Статус">
                            {% if plugin.enabled %}
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Активен</span>
                            {% else %}
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Отключён</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-3 text-right" data-label="Действия">
                            <div class="flex flex-wrap justify-end gap-2 md:gap-3">
                                <a href="{{ admin_url('plugins/' ~ plugin.name) }}" class="text-xs text-blue-600 hover:text-blue-800 font-medium">
                                    <i class="fas fa-cog mr-1"></i> Настроить
                                </a>
                                <form method="post" action="{{ admin_url('/plugins/toggle/' ~ plugin.name) }}" class="inline">
                                    <button type="submit" class="text-xs {% if plugin.enabled %}text-red-600 hover:text-red-800{% else %}text-green-600 hover:text-green-800{% endif %} font-medium">
                                        {{ plugin.enabled ? 'Деактивировать' : 'Активировать' }}
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}