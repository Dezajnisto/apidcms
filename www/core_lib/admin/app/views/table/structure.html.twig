{# twig #}
{% extends "base.html.twig" %}

{% block title %}{{ title }}{% endblock %}

{% block page_title %}{{ title }}{% endblock %}

{% block content %}
<div class="max-w-6xl mx-auto">
    <!-- Навигация (responsive) -->
    <div class="mb-4 md:mb-6 flex flex-wrap items-center gap-3">
        <a href="{{ admin_url('table/' ~ tableName|url_encode) }}" 
           class="inline-flex items-center space-x-2 text-blue-600 hover:text-blue-800 transition text-sm">
            <i class="fas fa-arrow-left"></i>
            <span>Назад к данным таблицы</span>
        </a>
        <a href="{{ admin_url('') }}" 
           class="inline-flex items-center space-x-2 text-gray-600 hover:text-gray-800 transition text-sm">
            <i class="fas fa-table"></i>
            <span>Список таблиц</span>
        </a>
    </div>

    <!-- Заголовок -->
    <div class="mb-4 md:mb-6">
        <h1 class="text-xl md:text-2xl font-bold text-gray-900">{{ title }}</h1>
        <p class="text-sm text-gray-600 mt-1">Просмотр и управление структурой таблицы</p>
    </div>

    <!-- Сообщения -->
    {% if _GET.column_added == '1' %}
        <div class="mb-4 md:mb-6 p-3 md:p-4 bg-green-100 border border-green-400 text-green-700 rounded-lg text-sm">
            <div class="flex items-center space-x-3">
                <i class="fas fa-check-circle"></i>
                <span>Колонка успешно добавлена</span>
            </div>
        </div>
    {% endif %}
    {% if _GET.column_deleted == '1' %}
        <div class="mb-4 md:mb-6 p-3 md:p-4 bg-blue-100 border border-blue-400 text-blue-700 rounded-lg text-sm">
            <div class="flex items-center space-x-3">
                <i class="fas fa-info-circle"></i>
                <span>Колонка успешно удалена</span>
            </div>
        </div>
    {% endif %}

    <!-- Действия -->
    <div class="mb-4 md:mb-6 flex flex-wrap gap-2 md:gap-4">
        <a href="{{ admin_url('table/' ~ tableName|url_encode ~ '/add-column') }}" 
           class="inline-flex items-center space-x-2 px-3 md:px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700 transition text-sm">
            <i class="fas fa-plus"></i>
            <span>Добавить колонку</span>
        </a>
        <a href="{{ admin_url('table/' ~ tableName|url_encode ~ '/delete-table') }}" 
           class="inline-flex items-center space-x-2 px-3 md:px-4 py-2 bg-red-600 text-white rounded-md hover:bg-red-700 transition text-sm"
           onclick="return confirm('ВНИМАНИЕ: Вы уверены, что хотите удалить таблицу? Это действие нельзя отменить.')">
            <i class="fas fa-trash"></i>
            <span>Удалить таблицу</span>
        </a>
    </div>

    <!-- Структура -->
    <div class="bg-white rounded-lg shadow-sm border">
        <div class="px-4 md:px-6 py-3 md:py-4 border-b">
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2">
                <h2 class="text-base md:text-lg font-semibold text-gray-900">Структура таблицы</h2>
                <div class="flex items-center space-x-3 text-xs md:text-sm text-gray-500">
                    <span class="flex items-center space-x-1">
                        <i class="fas fa-columns"></i>
                        <span>{{ structure|length }} колонок</span>
                    </span>
                    <span class="flex items-center space-x-1">
                        <i class="fas fa-key"></i>
                        <span>{{ structure|filter(col => col.pk)|length }} ключей</span>
                    </span>
                </div>
            </div>
        </div>
        
        <div class="p-4 md:p-6">
            {% if structure is empty %}
                <div class="text-center py-8 md:py-12">
                    <i class="fas fa-columns text-gray-400 text-4xl md:text-5xl mb-4"></i>
                    <p class="text-gray-500 text-base md:text-lg mb-2">Таблица не содержит колонок</p>
                    <p class="text-gray-400 text-sm mb-6">Добавьте первую колонку</p>
                    <a href="{{ admin_url('table/' ~ tableName|url_encode ~ '/add-column') }}" 
                       class="inline-flex items-center space-x-2 px-4 md:px-6 py-3 bg-green-600 text-white rounded-lg hover:bg-green-700 transition text-sm">
                        <i class="fas fa-plus"></i>
                        <span>Добавить первую колонку</span>
                    </a>
                </div>
            {% else %}
                <!-- Desktop table + mobile cards via data-table -->
                <div class="overflow-x-auto">
                    <table class="data-table min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 md:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Название</th>
                                <th class="px-4 md:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Тип</th>
                                <th class="px-4 md:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">NULL</th>
                                <th class="px-4 md:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">PK</th>
                                <th class="px-4 md:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">По умолч.</th>
                                <th class="px-4 md:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Действия</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            {% for column in structure %}
                            <tr class="hover:bg-gray-50 transition">
                                <td class="px-4 md:px-6 py-4 text-sm font-medium text-gray-900" data-label="Название">
                                    <div class="flex items-center space-x-3">
                                        <i class="fas fa-columns text-gray-400"></i>
                                        <span>{{ column.name }}</span>
                                        {% if column.name == 'id' %}
                                            <span class="ml-1 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">ID</span>
                                        {% endif %}
                                    </div>
                                </td>
                                <td class="px-4 md:px-6 py-4 text-sm" data-label="Тип">
                                    <code class="bg-gray-100 px-2 py-1 rounded text-xs">{{ column.type }}</code>
                                </td>
                                <td class="px-4 md:px-6 py-4" data-label="NULL">
                                    {% if column.notnull %}
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                            <i class="fas fa-times mr-1"></i>Нет
                                        </span>
                                    {% else %}
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                            <i class="fas fa-check mr-1"></i>Да
                                        </span>
                                    {% endif %}
                                </td>
                                <td class="px-4 md:px-6 py-4" data-label="PK">
                                    {% if column.pk %}
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                                            <i class="fas fa-key mr-1"></i>PK
                                        </span>
                                    {% else %}
                                        <span class="text-gray-400 text-sm">—</span>
                                    {% endif %}
                                </td>
                                <td class="px-4 md:px-6 py-4 text-sm" data-label="По умолч.">
                                    {% if column.dflt_value %}
                                        <code class="bg-gray-100 px-2 py-1 rounded text-xs">{{ column.dflt_value }}</code>
                                    {% else %}
                                        <span class="text-gray-400">NULL</span>
                                    {% endif %}
                                </td>
                                <td class="px-4 md:px-6 py-4" data-label="Действия">
                                    {% if not column.pk and column.name != 'id' %}
                                        <a href="{{ admin_url('table/' ~ tableName|url_encode ~ '/delete-column/' ~ column.name|url_encode) }}" 
                                           class="inline-flex items-center space-x-1 px-2 md:px-3 py-1 border border-red-300 text-red-700 rounded-md hover:bg-red-50 transition text-xs"
                                           onclick="return confirm('Удалить колонку?')">
                                            <i class="fas fa-trash"></i>
                                            <span class="hidden md:inline ml-1">Удалить</span>
                                        </a>
                                    {% else %}
                                        <span class="inline-flex items-center space-x-1 px-2 md:px-3 py-1 border border-gray-300 text-gray-400 rounded-md cursor-not-allowed text-xs">
                                            <i class="fas fa-lock"></i>
                                            <span class="hidden md:inline ml-1">Системная</span>
                                        </span>
                                    {% endif %}
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>

    <!-- Статистика таблицы -->
    {% if structure is not empty %}
    <div class="mt-4 md:mt-6 grid grid-cols-2 sm:grid-cols-4 gap-3 md:gap-4">
        <div class="bg-blue-50 p-3 md:p-4 rounded-lg border border-blue-200">
            <div class="flex items-center space-x-3">
                <i class="fas fa-columns text-blue-500"></i>
                <div>
                    <p class="text-lg md:text-2xl font-bold text-blue-700">{{ structure|length }}</p>
                    <p class="text-xs text-blue-600">Всего колонок</p>
                </div>
            </div>
        </div>
        <div class="bg-purple-50 p-3 md:p-4 rounded-lg border border-purple-200">
            <div class="flex items-center space-x-3">
                <i class="fas fa-key text-purple-500"></i>
                <div>
                    <p class="text-lg md:text-2xl font-bold text-purple-700">{{ structure|filter(col => col.pk)|length }}</p>
                    <p class="text-xs text-purple-600">Первичных ключей</p>
                </div>
            </div>
        </div>
        <div class="bg-green-50 p-3 md:p-4 rounded-lg border border-green-200">
            <div class="flex items-center space-x-3">
                <i class="fas fa-check-circle text-green-500"></i>
                <div>
                    <p class="text-lg md:text-2xl font-bold text-green-700">{{ structure|filter(col => not col.notnull)|length }}</p>
                    <p class="text-xs text-green-600">NULL колонок</p>
                </div>
            </div>
        </div>
        <div class="bg-orange-50 p-3 md:p-4 rounded-lg border border-orange-200">
            <div class="flex items-center space-x-3">
                <i class="fas fa-edit text-orange-500"></i>
                <div>
                    <p class="text-lg md:text-2xl font-bold text-orange-700">{{ structure|filter(col => not col.pk and col.name != 'id')|length }}</p>
                    <p class="text-xs text-orange-600">Редактируемых</p>
                </div>
            </div>
        </div>
    </div>

    <!-- SQL и info -->
    <div class="mt-4 md:mt-6 space-y-4">
        <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
            <div class="px-4 md:px-6 py-3 md:py-4 border-b border-gray-200 bg-gray-50">
                <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
                    <div class="flex items-center space-x-3">
                        <i class="fas fa-code text-gray-600"></i>
                        <h3 class="text-base md:text-lg font-semibold text-gray-900">SQL структура</h3>
                    </div>
                    <button onclick="copySqlStructure(event)" 
                            class="inline-flex items-center space-x-2 px-3 md:px-4 py-2 bg-blue-600 text-white text-xs md:text-sm rounded-md hover:bg-blue-700 transition">
                        <i class="far fa-copy"></i>
                        <span>Копировать SQL</span>
                    </button>
                </div>
            </div>
            <div class="p-4 md:p-6 bg-gray-900 text-gray-100 overflow-x-auto">
                <pre class="text-xs md:text-sm font-mono whitespace-pre"><code id="sqlStructure">CREATE TABLE "{{ tableName }}" ({{ "\n" }}{% for column in structure %}    "{{ column.name }}" {{ column.type }}{% if column.notnull == 0 %} NULL{% endif %}{% if column.dflt_value is not null %} DEFAULT {{ column.dflt_value }}{% endif %}{% if column.pk %} PRIMARY KEY{% endif %}{% if not loop.last %},{% endif %}{{ "\n" }}{% endfor %});</code></pre>
            </div>
        </div>

        <div class="p-3 md:p-4 bg-gray-50 rounded-lg border text-sm">
            <div class="flex items-start space-x-3">
                <i class="fas fa-info-circle text-gray-500 mt-1"></i>
                <div class="text-gray-700">
                    <strong class="font-medium">Информация о таблице:</strong>
                    <div class="mt-2 grid grid-cols-1 sm:grid-cols-2 gap-2 text-xs md:text-sm">
                        <div class="flex items-center space-x-2">
                            <i class="fas fa-table"></i>
                            <span>Название: <code class="bg-gray-200 px-1 rounded">{{ tableName }}</code></span>
                        </div>
                        <div class="flex items-center space-x-2">
                            <i class="fas fa-database"></i>
                            <span>БД: <code class="bg-gray-200 px-1 rounded">SQLite</code></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endif %}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.createElement('input');
    searchInput.type = 'text';
    searchInput.placeholder = 'Поиск по названию колонки...';
    searchInput.className = 'w-full px-3 md:px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 mb-4 text-sm';
    
    const table = document.querySelector('table');
    if (table) {
        table.parentNode.insertBefore(searchInput, table);
        
        searchInput.addEventListener('input', function() {
            const searchTerm = this.value.toLowerCase();
            const rows = table.querySelectorAll('tbody tr');
            rows.forEach(row => {
                const nameEl = row.querySelector('td:first-child .font-medium, td:first-child span');
                const columnName = nameEl ? nameEl.textContent.toLowerCase() : '';
                row.style.display = columnName.includes(searchTerm) ? '' : 'none';
            });
        });
    }
});

function copySqlStructure(event) {
    const sqlText = document.getElementById('sqlStructure').textContent;
    const textarea = document.createElement('textarea');
    textarea.value = sqlText;
    document.body.appendChild(textarea);
    textarea.select();
    textarea.setSelectionRange(0, 99999);
    
    try {
        const successful = document.execCommand('copy');
        const button = event.target.closest('button');
        
        if (successful) {
            const originalHtml = button.innerHTML;
            button.innerHTML = '<i class="fas fa-check"></i><span>Скопировано!</span>';
            button.classList.remove('bg-blue-600', 'hover:bg-blue-700');
            button.classList.add('bg-green-600', 'hover:bg-green-700');
            
            setTimeout(() => {
                button.innerHTML = originalHtml;
                button.classList.remove('bg-green-600', 'hover:bg-green-700');
                button.classList.add('bg-blue-600', 'hover:bg-blue-700');
            }, 2000);
        }
    } catch (err) {
        console.error('Ошибка при копировании: ', err);
    }
    
    document.body.removeChild(textarea);
}
</script>
{% endblock %}