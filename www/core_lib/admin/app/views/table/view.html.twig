{# twig #}
{% extends "base.html.twig" %}

{% block title %}{{ title }}

<!-- Inline cell editing modal (hidden by default) -->
<div id="cell-edit-modal" class="cell-modal-overlay" style="display:none;" aria-hidden="true">
    <div class="cell-modal">
        <div class="cell-modal-header">
            <div class="cell-modal-title" id="cell-modal-title"></div>
            <button type="button" class="cell-modal-close" id="cell-modal-close-btn" title="Escape">&times;</button>
        </div>
        <div class="cell-modal-body">
            <div class="cell-modal-error" id="cell-modal-error"></div>
            <textarea id="cell-modal-textarea" rows="10"></textarea>
        </div>
        <div class="cell-modal-footer">
            <span style="font-size:0.75rem;color:#9ca3af;margin-right:auto;">Ctrl+Enter = save, Esc = cancel</span>
            <button type="button" class="cell-btn cell-btn-cancel" id="cell-modal-mdeditor">MD Editor</button>
            <button type="button" class="cell-btn cell-btn-cancel" id="cell-modal-cancel">Cancel</button>
            <button type="button" class="cell-btn cell-btn-save" id="cell-modal-save">Save</button>
        </div>
    </div>
</div>

{% endblock %}

{% block page_title %}{{ title }}

<!-- Inline cell editing modal (hidden by default) -->
<div id="cell-edit-modal" class="cell-modal-overlay" style="display:none;" aria-hidden="true">
    <div class="cell-modal">
        <div class="cell-modal-header">
            <div class="cell-modal-title" id="cell-modal-title"></div>
            <button type="button" class="cell-modal-close" id="cell-modal-close-btn" title="Escape">&times;</button>
        </div>
        <div class="cell-modal-body">
            <div class="cell-modal-error" id="cell-modal-error"></div>
            <textarea id="cell-modal-textarea" rows="10"></textarea>
        </div>
        <div class="cell-modal-footer">
            <span style="font-size:0.75rem;color:#9ca3af;margin-right:auto;">Ctrl+Enter = save, Esc = cancel</span>
            <button type="button" class="cell-btn cell-btn-cancel" id="cell-modal-mdeditor">MD Editor</button>
            <button type="button" class="cell-btn cell-btn-cancel" id="cell-modal-cancel">Cancel</button>
            <button type="button" class="cell-btn cell-btn-save" id="cell-modal-save">Save</button>
        </div>
    </div>
</div>

{% endblock %}

{% block content %}
<style>
/* === Inline cell editing styles === */

/* Vertical cell separators */
.data-table td {
    border-right: 1px solid rgba(0,0,0,0.06);
}
.data-table td:last-child {
    border-right: none;
}

/* Cell hover effect */
.data-table td.td-cell {
    cursor: cell;
    transition: background-color 0.15s ease;
}
.data-table td.td-cell:hover {
    background-color: rgba(59, 130, 246, 0.06);
}

/* Saved flash animation */
.td-cell-saved {
    animation: cell-flash-green 0.8s ease;
}
@keyframes cell-flash-green {
    0%   { background-color: #bbf7d0; }
    100% { background-color: transparent; }
}

/* Error flash animation */
.td-cell-error {
    animation: cell-flash-red 0.8s ease;
}
@keyframes cell-flash-red {
    0%   { background-color: #fecaca; }
    100% { background-color: transparent; }
}

/* === Modal overlay === */
.cell-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
}

/* Modal card */
.cell-modal {
    background: #fff;
    border-radius: 0.75rem;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    width: 100%;
    max-width: 640px;
    max-height: 85vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

/* Modal header */
.cell-modal-header {
    padding: 1rem 1.5rem;
    border-bottom: 1px solid #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
}
.cell-modal-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: #1f2937;
}
.cell-modal-title code {
    background: #f3f4f6;
    padding: 0.125rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.85rem;
}

/* Modal close button */
.cell-modal-close {
    background: none;
    border: none;
    font-size: 1.25rem;
    color: #9ca3af;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 0.375rem;
    line-height: 1;
}
.cell-modal-close:hover {
    background: #f3f4f6;
    color: #374151;
}

/* Modal body */
.cell-modal-body {
    padding: 1rem 1.5rem;
    flex: 1;
    overflow-y: auto;
}
.cell-modal-body textarea {
    width: 100%;
    min-height: 200px;
    border: 1px solid #d1d5db;
    border-radius: 0.5rem;
    padding: 0.75rem;
    font-size: 0.875rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    line-height: 1.6;
    resize: vertical;
    outline: none;
    transition: border-color 0.15s ease;
}
.cell-modal-body textarea:focus {
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
}

/* Modal footer */
.cell-modal-footer {
    padding: 1rem 1.5rem;
    border-top: 1px solid #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.75rem;
    flex-shrink: 0;
}

/* Modal buttons */
.cell-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1.25rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    border: 1px solid transparent;
    transition: all 0.15s ease;
}
.cell-btn-save {
    background: #2563eb;
    color: #fff;
    border-color: #2563eb;
}
.cell-btn-save:hover {
    background: #1d4ed8;
}
.cell-btn-save:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}
.cell-btn-cancel {
    background: #fff;
    color: #374151;
    border-color: #d1d5db;
}
.cell-btn-cancel:hover {
    background: #f9fafb;
}

/* Modal error message */
.cell-modal-error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #b91c1c;
    padding: 0.625rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.8125rem;
    margin-bottom: 0.75rem;
    display: none;
}

/* === EasyMDE overrides for modal === */
.cell-modal-body .EasyMDEContainer {
    height: 100%;
}
.cell-modal-body .EasyMDEContainer .CodeMirror {
    height: 280px !important;
    border: 1px solid #d1d5db;
    border-radius: 0.5rem;
    font-size: 0.875rem;
}
.cell-modal-body .EasyMDEContainer .editor-toolbar {
    border: 1px solid #d1d5db;
    border-bottom: none;
    border-radius: 0.5rem 0.5rem 0 0;
    background: #f9fafb;
}
.cell-modal-body .EasyMDEContainer .editor-toolbar button {
    color: #374151;
}
.cell-modal-body .EasyMDEContainer .editor-toolbar button:hover {
    background: #e5e7eb;
    border-color: #d1d5db;
}
.cell-modal-body .EasyMDEContainer .editor-toolbar button.active {
    background: #e5e7eb;
    border-color: #9ca3af;
}
.cell-modal-body .EasyMDEContainer .editor-preview {
    background: #fff;
    padding: 0.75rem;
    border: 1px solid #d1d5db;
    border-top: none;
}
.cell-modal-body .EasyMDEContainer .editor-statusbar {
    font-size: 0.75rem;
    color: #9ca3af;
    padding: 0.25rem 0.5rem;
}
</style>

<div class="max-w-7xl mx-auto">
    <!-- Навигация -->
    <div class="mb-4 md:mb-6">
        <a href="{{ admin_url('') }}" 
           class="inline-flex items-center space-x-2 text-blue-600 hover:text-blue-800 transition text-sm md:text-base">
            <i class="fas fa-arrow-left"></i>
            <span>Назад к списку таблиц</span>
        </a>
    </div>

    <!-- Заголовок + AI кнопка -->
    <div class="mb-4 md:mb-6">
        <h1 class="text-xl md:text-2xl font-bold text-gray-900">{{ title }}</h1>

        <div class="mt-3 md:mt-4 flex flex-wrap gap-3">
            <button type="button" onclick="AIAssistant.init({mode:'content',tableName:'{{ tableName }}',count:5});AIAssistant.open()" 
                    class="inline-flex items-center space-x-2 px-3 md:px-4 py-2 border border-indigo-300 text-indigo-700 rounded-md hover:bg-indigo-50 transition text-sm">
                <i class="fas fa-magic"></i>
                <span>AI — Сгенерировать контент</span>
            </button>
        </div>
    </div>

    <!-- Сообщения -->
    {% if _GET.deleted == '1' %}
        <div class="mb-4 md:mb-6 p-3 md:p-4 bg-green-100 border border-green-400 text-green-700 rounded-lg text-sm">
            <div class="flex items-center space-x-3">
                <i class="fas fa-check-circle"></i>
                <span>Запись успешно удалена</span>
            </div>
        </div>
    {% endif %}

    <!-- Информация о таблице (stack on mobile) -->
    <div class="mb-4 md:mb-6 p-3 md:p-4 bg-gray-50 rounded-lg border">
        <div class="flex flex-col sm:flex-row flex-wrap items-start sm:items-center gap-2 md:gap-4 text-xs md:text-sm text-gray-700">
            <div class="flex items-center space-x-2">
                <i class="fas fa-table"></i>
                <span>Таблица: <code class="bg-gray-200 px-2 py-1 rounded">{{ tableName }}</code></span>
            </div>
            <div class="flex items-center space-x-2">
                <i class="fas fa-database"></i>
                <span>Записей: <span class="font-medium">{{ totalCount }}</span></span>
            </div>
            {% if search is not empty %}
            <div class="flex items-center space-x-2">
                <i class="fas fa-search"></i>
                <span>Найдено: <span class="font-medium text-blue-600">{{ totalCount }}</span></span>
            </div>
            {% endif %}
            <div class="flex items-center space-x-2">
                <i class="fas fa-columns"></i>
                <span>Колонок: <span class="font-medium">{{ structure|length }}</span></span>
            </div>
        </div>
    </div>

    <!-- Действия (stack on mobile) -->
    <div class="mb-4 md:mb-6 flex flex-wrap gap-2 md:gap-4">
        <a href="{{ admin_url('table/' ~ tableName|url_encode ~ '/create') }}" 
           class="inline-flex items-center space-x-2 px-3 md:px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700 transition text-sm">
            <i class="fas fa-plus"></i>
            <span>Добавить запись</span>
        </a>
        <a href="{{ admin_url('table/' ~ tableName|url_encode ~ '/structure') }}" 
           class="inline-flex items-center space-x-2 px-3 md:px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition text-sm">
            <i class="fas fa-cog"></i>
            <span>Структура</span>
        </a>
        <a href="{{ admin_url('table/' ~ tableName|url_encode ~ '/add-column') }}" 
           class="inline-flex items-center space-x-2 px-3 md:px-4 py-2 bg-purple-600 text-white rounded-md hover:bg-purple-700 transition text-sm">
            <i class="fas fa-columns"></i>
            <span>Колонку</span>
        </a>
    </div>

    <!-- Поиск -->
    <div class="mb-4 md:mb-6">
        <form method="GET" action="" class="flex flex-col sm:flex-row gap-3">
            <div class="flex-1">
                <input type="text" 
                       name="search" 
                       class="w-full px-3 md:px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm"
                       placeholder="Поиск по всем полям..." 
                       value="{{ search }}">
            </div>
            <div class="flex gap-2">
                <button type="submit" 
                        class="px-4 md:px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition flex items-center space-x-2 text-sm">
                    <i class="fas fa-search"></i>
                    <span>Найти</span>
                </button>
                {% if search is not empty %}
                    <a href="{{ admin_url('table/' ~ tableName|url_encode) }}" 
                       class="px-4 md:px-6 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition flex items-center space-x-2 text-sm">
                        <i class="fas fa-times"></i>
                        <span>Сбросить</span>
                    </a>
                {% endif %}
            </div>
        </form>
    </div>

    <!-- Результаты поиска -->
    {% if search is not empty %}
        <div class="mb-4 md:mb-6 p-3 md:p-4 bg-blue-50 border border-blue-200 rounded-lg text-sm">
            <div class="flex items-center space-x-3">
                <i class="fas fa-info-circle text-blue-500"></i>
                <div class="text-blue-700">
                    <strong>Результаты поиска:</strong> Найдено <span class="font-bold">{{ totalCount }}</span> записей по запросу "<span class="font-bold">{{ search }}</span>"
                </div>
            </div>
        </div>
    {% endif %}

    <!-- Таблица данных -->
    {% if data is empty %}
        <!-- Empty state -->
        <div class="bg-white rounded-lg shadow-sm border p-6 md:p-8 text-center">
            <i class="fas fa-inbox text-gray-400 text-4xl md:text-5xl mb-4"></i>
            <h2 class="text-lg md:text-xl font-semibold text-gray-900 mb-2">Данные не найдены</h2>
            <p class="text-gray-500 mb-6 text-sm md:text-base">
                {% if search is not empty %}
                    По запросу "{{ search }}" ничего не найдено.
                {% else %}
                    В таблице "{{ tableName }}" пока нет данных.
                {% endif %}
            </p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
                {% if search is not empty %}
                    <a href="{{ admin_url('table/' ~ tableName|url_encode) }}" 
                       class="inline-flex items-center space-x-2 px-4 md:px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition text-sm">
                        <i class="fas fa-list"></i>
                        <span>Показать все записи</span>
                    </a>
                {% else %}
                    <a href="{{ admin_url('table/' ~ tableName|url_encode ~ '/create') }}" 
                       class="inline-flex items-center space-x-2 px-4 md:px-6 py-3 bg-green-600 text-white rounded-lg hover:bg-green-700 transition text-sm">
                        <i class="fas fa-plus"></i>
                        <span>Добавить первую запись</span>
                    </a>
                {% endif %}
            </div>
        </div>
    {% else %}
        <!-- Data -->
        <div class="bg-white rounded-lg shadow-sm border overflow-hidden">
            <div class="px-4 md:px-6 py-3 md:py-4 border-b bg-gray-50">
                <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2">
                    <h2 class="text-base md:text-lg font-semibold text-gray-900">Данные таблицы</h2>
                    <div class="text-xs md:text-sm text-gray-500">
                        Страница {{ currentPage }} из {{ totalPages }} ({{ totalCount }} записей)
                    </div>
                </div>
            </div>
            
            <!-- Column toggles (mobile optimized) -->
            <div class="px-4 md:px-6 py-2 md:py-3 border-b bg-white flex flex-wrap items-center gap-1 md:gap-2" id="column-toggles">
                <span class="text-xs text-gray-400 mr-1 hidden sm:inline">Колонки:</span>
                {% set col_idx = 0 %}
                {% for column in structure %}
                    <label class="inline-flex items-center space-x-1 text-xs cursor-pointer hover:bg-gray-100 px-1.5 md:px-2 py-1 rounded" data-col="{{ col_idx }}">
                        <input type="checkbox" checked onchange="toggleColumn({{ col_idx }}, this.checked)" class="w-3 h-3 rounded border-gray-300 text-blue-600">
                        <span class="hidden sm:inline">{{ column.name }}</span>
                    </label>
                    {% set col_idx = col_idx + 1 %}
                {% endfor %}
                {% if hasIdColumn %}
                    <label class="inline-flex items-center space-x-1 text-xs cursor-pointer hover:bg-gray-100 px-1.5 md:px-2 py-1 rounded" data-col="actions">
                        <input type="checkbox" checked onchange="toggleColumn('actions', this.checked)" class="w-3 h-3 rounded border-gray-300 text-blue-600">
                        <span class="hidden sm:inline">Действия</span>
                    </label>
                {% endif %}
            </div>

            <div class="overflow-x-auto">
                <table class="data-table min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            {% set col_idx = 0 %}
                            {% set hasIdColumn = false %}
                            {% for column in structure %}
                                {% if column.name == 'id' %}
                                    {% set hasIdColumn = true %}
                                {% endif %}
                            {% endfor %}
                            
                            {% if hasIdColumn %}
                                <th class="px-4 md:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider cursor-pointer hover:bg-gray-100 transition" data-col="{{ col_idx }}"
                                    onclick="sortTable('id')">
                                    <div class="flex items-center space-x-1">
                                        <span>ID</span>
                                        {% if sort == 'id' %}
                                            <i class="fas fa-arrow-{{ order == 'ASC' ? 'up' : 'down' }} text-blue-500"></i>
                                        {% else %}
                                            <i class="fas fa-sort text-gray-300"></i>
                                        {% endif %}
                                    </div>
                                </th>
                                {% set col_idx = col_idx + 1 %}
                            {% endif %}
                            
                            {% for column in structure %}
                                {% if column.name != 'id' %}
                                    <th class="px-4 md:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider cursor-pointer hover:bg-gray-100 transition" data-col="{{ col_idx }}"
                                        onclick="sortTable('{{ column.name }}')">
                                        <div class="flex items-center space-x-1">
                                            <span>{{ column.name }}</span>
                                            {% if sort == column.name %}
                                                <i class="fas fa-arrow-{{ order == 'ASC' ? 'up' : 'down' }} text-blue-500"></i>
                                            {% else %}
                                                <i class="fas fa-sort text-gray-300"></i>
                                            {% endif %}
                                        </div>
                                    </th>
                                    {% set col_idx = col_idx + 1 %}
                                {% endif %}
                            {% endfor %}
                            
                            {% if hasIdColumn %}
                                <th class="px-4 md:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider" data-col="actions">
                                    Действия
                                </th>
                            {% endif %}
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        {% for row in data %}
                            <tr class="hover:bg-gray-50 transition">
                                {% if hasIdColumn %}
                                    <td class="px-4 md:px-6 py-4 text-sm font-medium text-gray-900 truncate" data-col="0" data-label="ID">
                                        {{ row.id ?? '' }}
                                    </td>
                                {% endif %}
                                
                                {% set td_col = 1 %}
                                {% for column in structure %}
                                    {% if column.name != 'id' %}
                                        {% set value = row[column.name] ?? '' %}
                                        <td class="td-cell px-4 md:px-6 py-4 text-sm text-gray-900" data-col="{{ td_col }}" data-label="{{ column.name }}" data-table="{{ tableName }}" data-row-id="{{ row.id }}" data-column="{{ column.name }}">
                                            {% if value is iterable %}
                                                <span class="italic">[Массив]</span>
                                            {% else %}
                                                <span class="block truncate max-w-[200px] md:max-w-xs break-word" title="{{ value }}">{{ value }}</span>
                                            {% endif %}
                                        </td>
                                        {% set td_col = td_col + 1 %}
                                    {% endif %}
                                {% endfor %}
                                
                                {% if hasIdColumn and row.id is defined %}
                                    <td class="px-4 md:px-6 py-4" data-col="actions">
                                        <div class="flex items-center space-x-2">
                                            <a href="{{ admin_url('table/' ~ tableName|url_encode ~ '/id/' ~ row.id) }}" 
                                               class="inline-flex items-center px-2 py-1.5 border border-blue-300 text-blue-700 rounded-md hover:bg-blue-50 transition text-xs"
                                               title="Просмотр">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="{{ admin_url('table/' ~ tableName|url_encode ~ '/edit/' ~ row.id ~ '?page=' ~ currentPage) }}" 
                                               class="inline-flex items-center px-2 py-1.5 border border-green-300 text-green-700 rounded-md hover:bg-green-50 transition text-xs"
                                               title="Редактировать">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a href="{{ admin_url('table/' ~ tableName|url_encode ~ '/duplicate/' ~ row.id) }}" 
                                               class="inline-flex items-center px-2 py-1.5 border border-amber-300 text-amber-700 rounded-md hover:bg-amber-50 transition text-xs"
                                               title="Копировать"
                                               onclick="return confirm('Создать копию записи #{{ row.id }}?')">
                                                <i class="fas fa-copy"></i>
                                            </a>
                                            <a href="{{ admin_url('table/' ~ tableName|url_encode ~ '/delete/' ~ row.id ~ '?page=' ~ currentPage) }}" 
                                               class="inline-flex items-center px-2 py-1.5 border border-red-300 text-red-700 rounded-md hover:bg-red-50 transition text-xs"
                                               title="Удалить"
                                               onclick="return confirm('Вы уверены, что хотите удалить запись #{{ row.id }}?')">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                {% endif %}
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Пагинация (responsive) -->
        {% if totalPages > 1 %}
            <div class="mt-4 md:mt-6 pagination-container flex flex-col sm:flex-row items-center justify-between gap-3">
                <div class="text-xs md:text-sm text-gray-500 text-center sm:text-left">
                    {{ ((currentPage - 1) * perPage) + 1 }} - {{ min(currentPage * perPage, totalCount) }} из {{ totalCount }} записей
                </div>
                <div class="pagination-pages flex items-center space-x-1 md:space-x-2">
                    {% if currentPage > 1 %}
                        <a href="?{{ _GET|merge({'page': 1})|url_encode }}" 
                           class="px-2 md:px-3 py-2 border border-gray-300 rounded-md hover:bg-gray-50 transition text-xs md:text-sm">
                            <i class="fas fa-angle-double-left"></i>
                        </a>
                        <a href="?{{ _GET|merge({'page': currentPage - 1})|url_encode }}" 
                           class="px-2 md:px-3 py-2 border border-gray-300 rounded-md hover:bg-gray-50 transition text-xs md:text-sm">
                            <i class="fas fa-angle-left"></i>
                        </a>
                    {% else %}
                        <span class="px-2 md:px-3 py-2 border border-gray-300 rounded-md text-gray-400 cursor-not-allowed text-xs md:text-sm">
                            <i class="fas fa-angle-double-left"></i>
                        </span>
                        <span class="px-2 md:px-3 py-2 border border-gray-300 rounded-md text-gray-400 cursor-not-allowed text-xs md:text-sm">
                            <i class="fas fa-angle-left"></i>
                        </span>
                    {% endif %}

                    <div class="flex items-center space-x-1">
                        {% for i in range(max(1, currentPage - 2), min(totalPages, currentPage + 2)) %}
                            {% if i == currentPage %}
                                <span class="px-2 md:px-3 py-2 bg-blue-600 text-white rounded-md text-xs md:text-sm">{{ i }}</span>
                            {% else %}
                                <a href="?{{ _GET|merge({'page': i})|url_encode }}" 
                                   class="px-2 md:px-3 py-2 border border-gray-300 rounded-md hover:bg-gray-50 transition text-xs md:text-sm">
                                    {{ i }}
                                </a>
                            {% endif %}
                        {% endfor %}
                    </div>

                    {% if currentPage < totalPages %}
                        <a href="?{{ _GET|merge({'page': currentPage + 1})|url_encode }}" 
                           class="px-2 md:px-3 py-2 border border-gray-300 rounded-md hover:bg-gray-50 transition text-xs md:text-sm">
                            <i class="fas fa-angle-right"></i>
                        </a>
                        <a href="?{{ _GET|merge({'page': totalPages})|url_encode }}" 
                           class="px-2 md:px-3 py-2 border border-gray-300 rounded-md hover:bg-gray-50 transition text-xs md:text-sm">
                            <i class="fas fa-angle-double-right"></i>
                        </a>
                    {% else %}
                        <span class="px-2 md:px-3 py-2 border border-gray-300 rounded-md text-gray-400 cursor-not-allowed text-xs md:text-sm">
                            <i class="fas fa-angle-right"></i>
                        </span>
                        <span class="px-2 md:px-3 py-2 border border-gray-300 rounded-md text-gray-400 cursor-not-allowed text-xs md:text-sm">
                            <i class="fas fa-angle-double-right"></i>
                        </span>
                    {% endif %}
                </div>
            </div>
        {% endif %}
    {% endif %}
</div>

<script>
function sortTable(column) {
    const urlParams = new URLSearchParams(window.location.search);
    let currentSort = urlParams.get('sort');
    let currentOrder = urlParams.get('order') || 'ASC';
    
    if (currentSort === column) {
        currentOrder = currentOrder === 'ASC' ? 'DESC' : 'ASC';
    } else {
        currentOrder = 'ASC';
    }
    
    urlParams.set('sort', column);
    urlParams.set('order', currentOrder);
    
    window.location.href = '?' + urlParams.toString();
}

// Переключатель видимости колонок
(function() {
    const tableKey = 'cols_{{ tableName }}';
    let saved = localStorage.getItem(tableKey);
    let hiddenCols = saved ? JSON.parse(saved) : [];

    if (!saved) {
        const ths = document.querySelectorAll('th[data-col]');
        ths.forEach(th => {
            const name = th.querySelector('span') ? th.querySelector('span').textContent.trim() : '';
            if (['created_at', 'updated_at'].includes(name)) {
                hiddenCols.push(th.getAttribute('data-col'));
            }
        });
        localStorage.setItem(tableKey, JSON.stringify(hiddenCols));
    }

    hiddenCols.forEach(col => {
        document.querySelectorAll('th[data-col="' + col + '"], td[data-col="' + col + '"]').forEach(el => el.style.display = 'none');
        const cb = document.querySelector('#column-toggles input[onchange*="toggleColumn(' + col + '"]');
        if (cb) cb.checked = false;
    });
})();

function toggleColumn(col, show) {
    const tableKey = 'cols_{{ tableName }}';
    let hiddenCols = JSON.parse(localStorage.getItem(tableKey)) || [];

    document.querySelectorAll('th[data-col="' + col + '"], td[data-col="' + col + '"]').forEach(el => {
        el.style.display = show ? '' : 'none';
    });

    if (show) {
        hiddenCols = hiddenCols.filter(c => c != col);
    } else if (!hiddenCols.includes(col)) {
        hiddenCols.push(col);
    }
    localStorage.setItem(tableKey, JSON.stringify(hiddenCols));
}

// Горячие клавиши
document.addEventListener('keydown', function(e) {
    if ((e.ctrlKey || e.metaKey) && e.key === 'n') {
        e.preventDefault();
        window.location.href = "{{ admin_url('table/' ~ tableName|url_encode ~ '/create') }}";
    }
});

// Автофокус на поле поиска
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.querySelector('input[name="search"]');
    if (searchInput && !searchInput.value) {
        searchInput.focus();
    }
});

<script src="https://cdn.jsdelivr.net/npm/easymde@2.21.0/dist/easymde.min.js"></script>
<script>
// ===== Inline cell editing =====
(function() {
    var modal = document.getElementById('cell-edit-modal');
    var modalTitle = document.getElementById('cell-modal-title');
    var modalTextarea = document.getElementById('cell-modal-textarea');
    var modalError = document.getElementById('cell-modal-error');
    var saveBtn = document.getElementById('cell-modal-save');
    var cancelBtn = document.getElementById('cell-modal-cancel');
    var closeBtn = document.getElementById('cell-modal-close-btn');
    var mdToggleBtn = document.getElementById('cell-modal-mdeditor');

    var currentCell = null;
    var currentTable = null;
    var currentRowId = null;
    var currentColumn = null;
    var currentOriginal = '';
    var easyMDEInstance = null;

    // Open modal on double-click
    document.querySelector('.data-table tbody').addEventListener('dblclick', function(e) {
        var td = e.target.closest('td.td-cell');
        if (!td) return;

        currentCell = td;
        currentTable = td.getAttribute('data-table');
        currentRowId = td.getAttribute('data-row-id');
        currentColumn = td.getAttribute('data-column');

        if (!currentTable || !currentRowId || !currentColumn) return;

        // Get current value
        var span = td.querySelector('.cell-value, span');
        currentOriginal = span ? span.textContent.trim() : td.textContent.trim();

        // Set modal
        modalTitle.innerHTML = 'Column <code>' + escapeHtml(currentColumn) + '</code> &middot; Record <code>#' + escapeHtml(currentRowId) + '</code> in <code>' + escapeHtml(currentTable) + '</code>';
        modalTextarea.value = currentOriginal;
        modalError.style.display = 'none';
        modalError.textContent = '';

        // Reset MD editor state
        if (easyMDEInstance) {
            easyMDEInstance.toTextArea();
            easyMDEInstance = null;
        }
        mdToggleBtn.textContent = 'MD Editor';

        // Show modal
        modal.style.display = 'flex';
        modal.setAttribute('aria-hidden', 'false');

        // Focus textarea and select all
        setTimeout(function() {
            modalTextarea.focus();
            modalTextarea.select();
        }, 50);

        e.preventDefault();
    });

    // Close modal
    function closeModal() {
        // Destroy EasyMDE instance if active
        if (easyMDEInstance) {
            easyMDEInstance.toTextArea();
            easyMDEInstance = null;
        }
        mdToggleBtn.textContent = 'MD Editor';

        modal.style.display = 'none';
        modal.setAttribute('aria-hidden', 'true');
        currentCell = null;
    }

    // Save handler
    function doSave() {
        if (!currentCell) return;

        var newValue = easyMDEInstance ? easyMDEInstance.value() : modalTextarea.value;
        if (newValue === currentOriginal) {
            closeModal();
            return;
        }

        saveBtn.disabled = true;
        modalError.style.display = 'none';

        fetch('/admin/table/' + encodeURIComponent(currentTable) + '/cell/' + encodeURIComponent(currentRowId), {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ column: currentColumn, value: newValue })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            saveBtn.disabled = false;
            if (data.success) {
                // Update cell display
                var span = currentCell.querySelector('.cell-value, span');
                if (span) {
                    span.textContent = newValue;
                    span.setAttribute('title', newValue);
                } else {
                    // For cells without a span wrapper
                    var textNode = Array.from(currentCell.childNodes).find(function(n) { return n.nodeType === 3 && n.textContent.trim(); });
                    if (textNode) textNode.textContent = newValue;
                }

                // Flash green
                currentCell.classList.add('td-cell-saved');
                setTimeout(function() { currentCell.classList.remove('td-cell-saved'); }, 800);

                closeModal();
            } else {
                modalError.textContent = data.error || 'Unknown error';
                modalError.style.display = 'block';
            }
        })
        .catch(function(err) {
            saveBtn.disabled = false;
            modalError.textContent = 'Network error: ' + err.message;
            modalError.style.display = 'block';

            // Flash red on original cell
            if (currentCell) {
                currentCell.classList.add('td-cell-error');
                setTimeout(function() { currentCell.classList.remove('td-cell-error'); }, 800);
            }
        });
    }

    // Cancel handler
    function doCancel() {
        closeModal();
    }

    // EasyMDE toggle handler
    mdToggleBtn.addEventListener('click', function() {
        if (easyMDEInstance) {
            // Switch back to plain textarea
            var currentValue = easyMDEInstance.value();
            easyMDEInstance.toTextArea();
            easyMDEInstance = null;
            modalTextarea.value = currentValue;
            mdToggleBtn.textContent = 'MD Editor';
        } else {
            // Switch to EasyMDE - do NOT hide textarea first,
            // EasyMDE wraps it and hides it itself
            easyMDEInstance = new EasyMDE({
                element: modalTextarea,
                spellChecker: false,
                status: ['lines', 'words'],
                minHeight: '280px',
                toolbar: ['bold', 'italic', 'heading', '|',
                          'quote', 'unordered-list', 'ordered-list', '|',
                          'link', 'image', '|',
                          'preview', 'side-by-side', 'fullscreen', '|',
                          'guide']
            });
            // Set value after EasyMDE initializes with the textarea content
            easyMDEInstance.codemirror.setValue(modalTextarea.value);
            easyMDEInstance.codemirror.refresh();
            mdToggleBtn.textContent = 'Plain Text';
        }
    });

    // Button handlers
    saveBtn.addEventListener('click', doSave);
    cancelBtn.addEventListener('click', doCancel);
    closeBtn.addEventListener('click', doCancel);

    // Click outside modal = close
    modal.addEventListener('click', function(e) {
        if (e.target === modal) doCancel();
    });

    // Keyboard shortcuts
    document.addEventListener('keydown', function(e) {
        if (modal.style.display !== 'flex') return;

        if (e.key === 'Escape') {
            e.preventDefault();
            doCancel();
        } else if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) {
            e.preventDefault();
            doSave();
        }
    });

    // Escape HTML helper
    function escapeHtml(str) {
        var div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
    }
})();

</script>


<!-- Inline cell editing modal (hidden by default) -->
<div id="cell-edit-modal" class="cell-modal-overlay" style="display:none;" aria-hidden="true">
    <div class="cell-modal">
        <div class="cell-modal-header">
            <div class="cell-modal-title" id="cell-modal-title"></div>
            <button type="button" class="cell-modal-close" id="cell-modal-close-btn" title="Escape">&times;</button>
        </div>
        <div class="cell-modal-body">
            <div class="cell-modal-error" id="cell-modal-error"></div>
            <textarea id="cell-modal-textarea" rows="10"></textarea>
        </div>
        <div class="cell-modal-footer">
            <span style="font-size:0.75rem;color:#9ca3af;margin-right:auto;">Ctrl+Enter = save, Esc = cancel</span>
            <button type="button" class="cell-btn cell-btn-cancel" id="cell-modal-mdeditor">MD Editor</button>
            <button type="button" class="cell-btn cell-btn-cancel" id="cell-modal-cancel">Cancel</button>
            <button type="button" class="cell-btn cell-btn-save" id="cell-modal-save">Save</button>
        </div>
    </div>
</div>

{% endblock %}