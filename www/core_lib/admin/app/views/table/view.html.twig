{# twig #}
{% extends "base.html.twig" %}

{% block title %}{{ title }}{% endblock %}

{% block page_title %}{{ title }}{% endblock %}

{% block content %}
<style>
/* === Inline cell editing styles === */

/* Vertical cell separators */
.data-table td {
    border-right: 1px solid rgba(0,0,0,0.06);
}
.data-table td:last-child {
    border-right: none;
}

/* Cell hover effect */
.data-table td.td-cell {
    cursor: cell;
    transition: background-color 0.15s ease;
}
.data-table td.td-cell:hover {
    background-color: rgba(59, 130, 246, 0.06);
}

/* Saved flash animation */
.td-cell-saved {
    animation: cell-flash-green 0.8s ease;
}
@keyframes cell-flash-green {
    0%   { background-color: #bbf7d0; }
    100% { background-color: transparent; }
}

/* Error flash animation */
.td-cell-error {
    animation: cell-flash-red 0.8s ease;
}
@keyframes cell-flash-red {
    0%   { background-color: #fecaca; }
    100% { background-color: transparent; }
}

/* === Modal overlay === */
.cell-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
}

/* Modal card */
.cell-modal {
    background: #fff;
    border-radius: 0.75rem;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    width: 100%;
    max-width: 640px;
    max-height: 85vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

/* Modal header */
.cell-modal-header {
    padding: 1rem 1.5rem;
    border-bottom: 1px solid #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
}
.cell-modal-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: #1f2937;
}
.cell-modal-title code {
    background: #f3f4f6;
    padding: 0.125rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.85rem;
}

/* Modal close button */
.cell-modal-close {
    background: none;
    border: none;
    font-size: 1.25rem;
    color: #9ca3af;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 0.375rem;
    line-height: 1;
}
.cell-modal-close:hover {
    background: #f3f4f6;
    color: #374151;
}

/* Modal body */
.cell-modal-body {
    padding: 1rem 1.5rem;
    flex: 1;
    overflow-y: auto;
}
.cell-modal-body textarea {
    width: 100%;
    min-height: 200px;
    border: 1px solid #d1d5db;
    border-radius: 0.5rem;
    padding: 0.75rem;
    font-size: 0.875rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    line-height: 1.6;
    resize: vertical;
    outline: none;
    transition: border-color 0.15s ease;
}
.cell-modal-body textarea:focus {
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
}

/* Modal footer */
.cell-modal-footer {
    padding: 1rem 1.5rem;
    border-top: 1px solid #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.75rem;
    flex-shrink: 0;
}

/* Modal buttons */
.cell-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1.25rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    border: 1px solid transparent;
    transition: all 0.15s ease;
}
.cell-btn-save {
    background: #2563eb;
    color: #fff;
    border-color: #2563eb;
}
.cell-btn-save:hover {
    background: #1d4ed8;
}
.cell-btn-save:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}
.cell-btn-cancel {
    background: #fff;
    color: #374151;
    border-color: #d1d5db;
}
.cell-btn-cancel:hover {
    background: #f9fafb;
}

/* Modal error message */
.cell-modal-error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #b91c1c;
    padding: 0.625rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.8125rem;
    margin-bottom: 0.75rem;
    display: none;
}


