{# twig #}
{% extends "base.html.twig" %}

{% block title %}{{ title }}{% endblock %}

{% block page_title %}{{ title }}{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto">
    <!-- Заголовок и кнопка назад -->
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-gray-900">{{ title }}</h1>
        <a href="/admin/templates" 
           class="inline-flex items-center space-x-2 px-4 py-2 border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 transition">
            <i class="fas fa-arrow-left"></i>
            <span>Назад к списку</span>
        </a>
    </div>

    <!-- Сообщения об ошибках -->
    {% if error %}
        <div class="mb-6 p-4 bg-red-100 border border-red-400 text-red-700 rounded-lg">
            <div class="flex items-center space-x-3">
                <i class="fas fa-exclamation-circle"></i>
                <span>{{ error }}</span>
            </div>
        </div>
    {% endif %}

    <!-- Форма создания шаблона -->
    <div class="bg-white rounded-lg shadow-sm border">
        <div class="px-6 py-4 border-b">
            <h2 class="text-lg font-semibold text-gray-900">Создание нового шаблона</h2>
        </div>
        
        <div class="p-6">
            <form method="post" class="space-y-6">
                <!-- Название шаблона -->
                <div>
                    <label for="templateName" class="block text-sm font-medium text-gray-700 mb-2">
                        Название шаблона <span class="text-red-500">*</span>
                    </label>
                    <input type="text" 
                           id="templateName" 
                           name="template_name" 
                           value="{{ formData.template_name ?? '' }}" 
                           placeholder="например: my_template.html.twig" 
                           required
                           class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                    <p class="mt-1 text-sm text-gray-500">
                        Имя должно заканчиваться на <code class="text-blue-600">.html.twig</code>. 
                        Допустимы буквы, цифры, дефисы и подчеркивания.
                    </p>
                </div>

                <!-- Содержимое шаблона -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        Содержимое шаблона <span class="text-red-500">*</span>
                    </label>
                    <textarea name="content" 
                              rows="20" 
                              class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 font-mono text-sm"
                              placeholder="{% verbatim %}{% extends &quot;base.html.twig&quot; %}

{% block title %}Заголовок страницы{% endblock %}

{% block content %}
    <h1>Мой шаблон</h1>
    <p>Содержимое страницы</p>
{% endblock %}{% endverbatim %}">{{ formData.content ?? '' }}</textarea>
                </div>

                <!-- Подсказка -->
                <div class="p-4 bg-blue-50 border border-blue-200 rounded-lg">
                    <div class="flex items-start space-x-3">
                        <i class="fas fa-info-circle text-blue-500 mt-1"></i>
                        <div class="text-sm text-blue-700">
                            <strong class="font-medium">Рекомендация:</strong>
                            <p>Начните с расширения базового шаблона используя 
                                <code class="bg-blue-100 px-1 rounded">{% verbatim %}{% extends "base.html.twig" %}{% endverbatim %}</code>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Кнопки действий -->
                <div class="flex items-center justify-end space-x-4 pt-6 border-t">
                    <a href="/admin/templates" 
                       class="px-6 py-2 border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 transition">
                        Отмена
                    </a>
                    <button type="submit" 
                            class="px-6 py-2 bg-green-600 text-white rounded-md hover:bg-green-700 transition flex items-center space-x-2">
                        <i class="fas fa-plus"></i>
                        <span>Создать шаблон</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const textarea = document.querySelector('textarea[name="content"]');
    
    // Увеличиваем высоту при фокусе для удобства редактирования
    if (textarea) {
        textarea.addEventListener('focus', function() {
            this.style.minHeight = '500px';
        });
        
        // Автоматическое добавление .html.twig если забыли
        const nameInput = document.getElementById('templateName');
        nameInput.addEventListener('blur', function() {
            let value = this.value.trim();
            if (value && !value.endsWith('.html.twig')) {
                this.value = value + '.html.twig';
            }
        });
    }
});
</script>
{% endblock %}