{# twig #}
{% extends "base.html.twig" %}

{% block title %}{{ title }}{% endblock %}

{% block page_title %}{{ title }}{% endblock %}

{% block content %}
<div class="max-w-6xl mx-auto">
    <!-- Заголовок и кнопка создания -->
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-gray-900">{{ title }}</h1>
        <a href="/admin/templates/create" 
           class="inline-flex items-center space-x-2 px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700 transition">
            <i class="fas fa-plus"></i>
            <span>Создать шаблон</span>
        </a>
    </div>

    <!-- Сообщения об успехе -->
    {% if _GET.saved %}
        <div class="mb-6 p-4 bg-green-100 border border-green-400 text-green-700 rounded-lg">
            <div class="flex items-center space-x-3">
                <i class="fas fa-check-circle"></i>
                <span>Шаблон успешно сохранен!</span>
            </div>
        </div>
    {% endif %}
    {% if _GET.created %}
        <div class="mb-6 p-4 bg-green-100 border border-green-400 text-green-700 rounded-lg">
            <div class="flex items-center space-x-3">
                <i class="fas fa-check-circle"></i>
                <span>Шаблон успешно создан!</span>
            </div>
        </div>
    {% endif %}
    {% if _GET.deleted %}
        <div class="mb-6 p-4 bg-green-100 border border-green-400 text-green-700 rounded-lg">
            <div class="flex items-center space-x-3">
                <i class="fas fa-check-circle"></i>
                <span>Шаблон успешно удален!</span>
            </div>
        </div>
    {% endif %}

    <!-- Карточка со списком шаблонов -->
    <div class="bg-white rounded-lg shadow-sm border">
        <div class="px-6 py-4 border-b">
            <h2 class="text-lg font-semibold text-gray-900">Список шаблонов</h2>
        </div>
        
        <div class="p-6">
            {% if templates is empty %}
                <!-- Состояние пустого списка -->
                <div class="text-center py-12">
                    <i class="fas fa-file-code text-gray-400 text-5xl mb-4"></i>
                    <p class="text-gray-500 text-lg mb-2">Шаблоны не найдены</p>
                    <p class="text-gray-400 text-sm mb-6">Создайте свой первый шаблон для начала работы</p>
                    <a href="/admin/templates/create" 
                       class="inline-flex items-center space-x-2 px-6 py-3 bg-green-600 text-white rounded-lg hover:bg-green-700 transition">
                        <i class="fas fa-plus"></i>
                        <span>Создать первый шаблон</span>
                    </a>
                </div>
            {% else %}
                <!-- Таблица шаблонов -->
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                    Название
                                </th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                    Размер
                                </th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                    Изменен
                                </th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                    Действия
                                </th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            {% for template in templates %}
                            <tr class="hover:bg-gray-50 transition">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center space-x-3">
                                        <i class="fas fa-file-code text-gray-400"></i>
                                        <div>
                                            <div class="flex items-center space-x-2">
                                                <span class="font-medium text-gray-900">{{ template.name }}</span>
                                                {% if template.is_base %}
                                                    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                                        Базовый
                                                    </span>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    {{ (template.size / 1024)|number_format(2) }} КБ
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    <div class="flex items-center space-x-2">
                                        <i class="fas fa-clock text-gray-400"></i>
                                        <span>{{ template.modified|date('d.m.Y H:i') }}</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                    <div class="flex items-center space-x-2">
                                        <!-- Предпросмотр -->
                                        <a href="{{ admin_url('templates/preview/' ~ template.name|url_encode) }}" 
                                        class="inline-flex items-center space-x-1 px-3 py-1 border border-blue-300 text-blue-700 rounded-md hover:bg-blue-50 transition"
                                        title="Предпросмотр">
                                            <i class="fas fa-eye"></i>
                                            <span class="hidden sm:inline">Просмотр</span>
                                        </a>
                                        
                                        <!-- Редактирование -->
                                        <a href="{{ admin_url('templates/edit/' ~ template.name|url_encode) }}" 
                                        class="inline-flex items-center space-x-1 px-3 py-1 border border-green-300 text-green-700 rounded-md hover:bg-green-50 transition"
                                        title="Редактировать">
                                            <i class="fas fa-edit"></i>
                                            <span class="hidden sm:inline">Редакт.</span>
                                        </a>
                                        
                                        <!-- Удаление (только не базовых) -->
                                        {% if not template.is_base %}
                                        <a href="{{ admin_url('templates/delete/' ~ template.name|url_encode) }}" 
                                        class="inline-flex items-center space-x-1 px-3 py-1 border border-red-300 text-red-700 rounded-md hover:bg-red-50 transition"
                                        onclick="return confirm('Удалить шаблон «{{ template.name }}»?')"
                                        title="Удалить">
                                            <i class="fas fa-trash"></i>
                                            <span class="hidden sm:inline">Удалить</span>
                                        </a>
                                        {% else %}
                                        <span class="inline-flex items-center space-x-1 px-3 py-1 border border-gray-300 text-gray-400 rounded-md cursor-not-allowed"
                                            title="Базовый шаблон нельзя удалить">
                                            <i class="fas fa-trash"></i>
                                            <span class="hidden sm:inline">Удалить</span>
                                        </span>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>

    <!-- Информация о пути -->
    <div class="mt-6 p-4 bg-gray-50 rounded-lg border">
        <div class="flex items-center space-x-3">
            <i class="fas fa-folder text-gray-400"></i>
            <div>
                <p class="text-sm font-medium text-gray-700">Путь к шаблонам:</p>
                <p class="text-sm text-gray-500 font-mono">{{ templatesPath }}</p>
            </div>
        </div>
    </div>

    <!-- Статистика -->
    {% if templates is not empty %}
    <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-blue-50 p-4 rounded-lg border border-blue-200">
            <div class="flex items-center space-x-3">
                <i class="fas fa-file-code text-blue-500 text-xl"></i>
                <div>
                    <p class="text-2xl font-bold text-blue-700">{{ templates|length }}</p>
                    <p class="text-sm text-blue-600">Всего шаблонов</p>
                </div>
            </div>
        </div>
        <div class="bg-green-50 p-4 rounded-lg border border-green-200">
            <div class="flex items-center space-x-3">
                <i class="fas fa-hdd text-green-500 text-xl"></i>
                <div>
                    <p class="text-2xl font-bold text-green-700">
                        {{ (templates|reduce((sum, t) => sum + t.size, 0) / 1024)|number_format(2) }} КБ
                    </p>
                    <p class="text-sm text-green-600">Общий размер</p>
                </div>
            </div>
        </div>
        <div class="bg-purple-50 p-4 rounded-lg border border-purple-200">
            <div class="flex items-center space-x-3">
                <i class="fas fa-clock text-purple-500 text-xl"></i>
                <div>
                    <p class="text-2xl font-bold text-purple-700">
                        {{ templates|sort((a, b) => b.modified <=> a.modified)|first.modified|date('d.m.Y') }}
                    </p>
                    <p class="text-sm text-purple-600">Последнее изменение</p>
                </div>
            </div>
        </div>
    </div>
    {% endif %}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Добавляем поиск по таблице
    const searchInput = document.createElement('input');
    searchInput.type = 'text';
    searchInput.placeholder = 'Поиск по названию шаблона...';
    searchInput.className = 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 mb-4';
    
    const table = document.querySelector('table');
    if (table) {
        table.parentNode.insertBefore(searchInput, table);
        
        searchInput.addEventListener('input', function() {
            const searchTerm = this.value.toLowerCase();
            const rows = table.querySelectorAll('tbody tr');
            
            rows.forEach(row => {
                const templateName = row.querySelector('td:first-child .font-medium').textContent.toLowerCase();
                if (templateName.includes(searchTerm)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    }
});
</script>
{% endblock %}