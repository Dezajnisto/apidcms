{# twig #}
{% extends "base.html.twig" %}

{% block title %}{{ title }}{% endblock %}

{% block page_title %}{{ title }}{% endblock %}

{% block content %}
<div class="max-w-6xl mx-auto">
    <!-- Заголовок и кнопки управления -->
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">{{ title }}</h1>
            <p class="text-sm text-gray-500 mt-1">Предпросмотр исходного кода</p>
        </div>
        <div class="flex items-center space-x-3">
            <a href="/admin/templates/edit/{{ templateName|url_encode }}" 
               class="inline-flex items-center space-x-2 px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition">
                <i class="fas fa-edit"></i>
                <span>Редактировать</span>
            </a>
            <a href="/admin/templates" 
               class="inline-flex items-center space-x-2 px-4 py-2 border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 transition">
                <i class="fas fa-arrow-left"></i>
                <span>Назад к списку</span>
            </a>
        </div>
    </div>

    <!-- Карточка с кодом -->
    <div class="bg-white rounded-lg shadow-sm border">
        <div class="px-6 py-4 border-b">
            <div class="flex items-center justify-between">
                <h2 class="text-lg font-semibold text-gray-900">Исходный код шаблона</h2>
                <div class="flex items-center space-x-3">
                    <button onclick="copyToClipboard()" 
                            class="inline-flex items-center space-x-2 px-3 py-1 border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 transition text-sm">
                        <i class="fas fa-copy"></i>
                        <span>Копировать</span>
                    </button>
                    <button onclick="toggleWrap()" 
                            class="inline-flex items-center space-x-2 px-3 py-1 border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 transition text-sm">
                        <i class="fas fa-text-width"></i>
                        <span id="wrapToggle">Переносы: Вкл</span>
                    </button>
                </div>
            </div>
        </div>
        
        <div class="p-6">
            <div class="relative">
                <pre id="codePreview" 
                     class="bg-gray-900 text-gray-100 p-6 rounded-lg overflow-x-auto text-sm leading-relaxed whitespace-pre-wrap">
<code class="language-twig">{{ content|raw }}</code></pre>
                
                <!-- Индикатор копирования -->
                <div id="copyNotification" 
                     class="hidden fixed top-4 right-4 bg-green-600 text-white px-4 py-2 rounded-lg shadow-lg z-50">
                    <div class="flex items-center space-x-2">
                        <i class="fas fa-check"></i>
                        <span>Код скопирован!</span>
                    </div>
                </div>
            </div>
            
            <!-- Информация о файле -->
            <div class="mt-4 flex items-center justify-between text-sm text-gray-500">
                <div class="flex items-center space-x-4">
                    <span class="flex items-center space-x-1">
                        <i class="fas fa-file-code"></i>
                        <span>{{ templateName }}</span>
                    </span>
                    <span class="flex items-center space-x-1">
                        <i class="fas fa-ruler"></i>
                        <span id="lineCount">Строк: {{ content|split('\n')|length }}</span>
                    </span>
                    <span class="flex items-center space-x-1">
                        <i class="fas fa-font"></i>
                        <span id="charCount">Символов: {{ content|length }}</span>
                    </span>
                </div>
                <div class="flex items-center space-x-2">
                    <span class="text-xs bg-gray-200 px-2 py-1 rounded">Twig</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Предупреждение -->
    <div class="mt-6 p-4 bg-yellow-50 border border-yellow-200 rounded-lg">
        <div class="flex items-start space-x-3">
            <i class="fas fa-exclamation-triangle text-yellow-500 mt-1"></i>
            <div class="text-sm text-yellow-700">
                <strong class="font-medium">Внимание!:</strong>
                <p>Это только предпросмотр исходного кода. Чтобы увидеть как шаблон выглядит на сайте, 
                   откройте соответствующую страницу на фронтенде.</p>
            </div>
        </div>
    </div>

    <!-- Быстрые действия -->
    <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-blue-50 p-4 rounded-lg border border-blue-200">
            <h3 class="font-medium text-blue-900 mb-2">Следующие шаги</h3>
            <ul class="text-sm text-blue-700 space-y-1">
                <li class="flex items-center space-x-2">
                    <i class="fas fa-edit text-blue-500"></i>
                    <span>Отредактируйте шаблон для изменения внешнего вида</span>
                </li>
                <li class="flex items-center space-x-2">
                    <i class="fas fa-code text-blue-500"></i>
                    <span>Используйте Twig синтаксис для динамического контента</span>
                </li>
                <li class="flex items-center space-x-2">
                    <i class="fas fa-eye text-blue-500"></i>
                    <span>Проверьте результат на соответствующей странице сайта</span>
                </li>
            </ul>
        </div>
        
        <div class="bg-green-50 p-4 rounded-lg border border-green-200">
            <h3 class="font-medium text-green-900 mb-2">Полезные советы</h3>
            <ul class="text-sm text-green-700 space-y-1">
                <li class="flex items-center space-x-2">
                    <i class="fas fa-copy text-green-500"></i>
                    <span>Используйте кнопку "Копировать" для быстрого переноса кода</span>
                </li>
                <li class="flex items-center space-x-2">
                    <i class="fas fa-text-width text-green-500"></i>
                    <span>Включите/выключите переносы текста для удобства чтения</span>
                </li>
                <li class="flex items-center space-x-2">
                    <i class="fas fa-sync text-green-500"></i>
                    <span>После редактирования обновите страницу для проверки изменений</span>
                </li>
            </ul>
        </div>
    </div>
</div>

<script>
{% verbatim %}
document.addEventListener('DOMContentLoaded', function() {
    updateStats();
    
    function updateStats() {
        const codeElement = document.querySelector('code.language-twig');
        if (!codeElement) return;
        
        const content = codeElement.textContent;
        const lineCount = document.getElementById('lineCount');
        const charCount = document.getElementById('charCount');
        
        if (lineCount && charCount) {
            const lines = content.split('\n').length;
            const chars = content.length;
            
            lineCount.textContent = 'Строк: ' + lines;
            charCount.textContent = 'Символов: ' + chars;
        }
    }
});

// Копирование в буфер обмена
function copyToClipboard() {
    const codeElement = document.querySelector('code.language-twig');
    if (!codeElement) return;
    
    const textArea = document.createElement('textarea');
    textArea.value = codeElement.textContent;
    document.body.appendChild(textArea);
    textArea.select();
    
    try {
        document.execCommand('copy');
        
        // Показываем уведомление
        const notification = document.getElementById('copyNotification');
        notification.classList.remove('hidden');
        notification.classList.add('flex');
        
        setTimeout(function() {
            notification.classList.add('hidden');
            notification.classList.remove('flex');
        }, 2000);
    } catch (err) {
        console.error('Ошибка при копировании:', err);
    } finally {
        document.body.removeChild(textArea);
    }
}

// Переключение переносов текста
let wrapEnabled = true;
function toggleWrap() {
    const codePreview = document.getElementById('codePreview');
    const wrapToggle = document.getElementById('wrapToggle');
    
    if (!codePreview || !wrapToggle) return;
    
    wrapEnabled = !wrapEnabled;
    
    if (wrapEnabled) {
        codePreview.classList.add('whitespace-pre-wrap');
        codePreview.classList.remove('whitespace-pre');
        wrapToggle.textContent = 'Переносы: Вкл';
    } else {
        codePreview.classList.remove('whitespace-pre-wrap');
        codePreview.classList.add('whitespace-pre');
        wrapToggle.textContent = 'Переносы: Выкл';
    }
}

// Базовая подсветка синтаксиса Twig
function highlightTwigSyntax() {
    const codeElement = document.querySelector('code.language-twig');
    if (!codeElement) return;
    
    let code = codeElement.innerHTML;
    
    // Экранируем HTML сущности перед обработкой
    code = code.replace(/&/g, '&amp;')
               .replace(/</g, '&lt;')
               .replace(/>/g, '&gt;')
               .replace(/"/g, '&quot;')
               .replace(/'/g, '&#039;');
    
    // Подсветка Twig тегов {% ... %} и {{ ... }}
    code = code.replace(/(\{%[-~]?)(.*?)([-~]?%\})/g, '<span class="text-purple-400 font-bold">$1</span><span class="text-yellow-300">$2</span><span class="text-purple-400 font-bold">$3</span>');
    code = code.replace(/(\{\{[-~]?)(.*?)([-~]?\}\})/g, '<span class="text-blue-400 font-bold">$1</span><span class="text-green-400">$2</span><span class="text-blue-400 font-bold">$3</span>');
    
    // Подсветка комментариев {# ... #}
    code = code.replace(/(\{#)(.*?)(#\})/g, '<span class="text-gray-500 italic">$1$2$3</span>');
    
    // Подсветка фильтров и функций
    code = code.replace(/(\|\s*[a-zA-Z_][a-zA-Z0-9_]*)/g, '<span class="text-orange-400">$1</span>');
    code = code.replace(/([a-zA-Z_][a-zA-Z0-9_]*\s*\()/g, '<span class="text-cyan-400">$1</span>');
    
    codeElement.innerHTML = code;
}

// Запускаем подсветку при загрузке
document.addEventListener('DOMContentLoaded', highlightTwigSyntax);

// Горячие клавиши
document.addEventListener('keydown', function(e) {
    if ((e.ctrlKey || e.metaKey) && e.key === 'c') {
        // Если выделен текст в коде, разрешаем стандартное копирование
        const selection = window.getSelection();
        if (selection.toString().length > 0 && selection.containsNode(document.querySelector('code.language-twig'), true)) {
            return;
        }
        
        e.preventDefault();
        copyToClipboard();
    }
});
{% endverbatim %}
</script>

<style>
/* Дополнительные стили для лучшего отображения кода */
.language-twig {
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
    tab-size: 4;
    -moz-tab-size: 4;
}

/* Подсветка синтаксиса */
.text-purple-400 { color: #c084fc; }
.text-yellow-300 { color: #fde047; }
.text-green-400 { color: #4ade80; }
.text-blue-400 { color: #60a5fa; }
.text-orange-400 { color: #fb923c; }
.text-cyan-400 { color: #22d3ee; }
.text-gray-500 { color: #6b7280; }

/* Плавная анимация для уведомлений */
#copyNotification {
    animation: slideIn 0.3s ease-out;
}

@keyframes slideIn {
    from {
        transform: translateX(100%);
        opacity: 0;
    }
    to {
        transform: translateX(0);
        opacity: 1;
    }
}

/* Стили для скроллбара */
pre::-webkit-scrollbar {
    height: 8px;
}

pre::-webkit-scrollbar-track {
    background: #1f2937;
    border-radius: 0 0 4px 4px;
}

pre::-webkit-scrollbar-thumb {
    background: #4b5563;
    border-radius: 4px;
}

pre::-webkit-scrollbar-thumb:hover {
    background: #6b7280;
}
</style>
{% endblock %}