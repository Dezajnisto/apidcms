{% extends "base.html.twig" %}

{% block title %}{{ title }} | {{ site_title }}{% endblock %}

{% block content %}
<div class="page-header">
    <h1>{{ title }}</h1>
    {% if nav_item.page_type == 'blog' %}
        <p class="page-subtitle">Блог и новости</p>
    {% endif %}
</div>

<div class="content-list">
    {% if items %}
        {% for item in items %}
            <article class="content-item">
                {% if item.featured_image %}
                    <div class="item-image">
                        <img src="{{ url('storage/uploads/' ~ item.featured_image) }}" alt="{{ item.title }}">
                    </div>
                {% endif %}
                
                <div class="item-content">
                    <h2 class="item-title">
                        <a href="{{ url(nav_item.url ~ '/' ~ item.slug) }}">{{ item.title ?? item.name }}</a>
                    </h2>
                    
                    <div class="item-meta">
                        {% if item.created_at %}
                            <time datetime="{{ item.created_at|date('Y-m-d') }}">
                                {{ item.created_at|date('d.m.Y') }}
                            </time>
                        {% endif %}
                        {% if item.author_name %}
                            <span class="item-author">by {{ item.author_name }}</span>
                        {% endif %}
                    </div>
                    
                    {% if item.excerpt %}
                        <div class="item-excerpt">
                            {{ item.excerpt }}
                        </div>
                    {% elseif item.content %}
                        <div class="item-excerpt">
                            {{ item.content|striptags|slice(0, 200) }}...
                        </div>
                    {% elseif item.description %}
                        <div class="item-excerpt">
                            {{ item.description|striptags|slice(0, 200) }}...
                        </div>
                    {% endif %}
                    
                    <a href="{{ url(nav_item.url ~ '/' ~ item.slug) }}" class="read-more">Подробнее</a>
                </div>
            </article>
        {% endfor %}
    {% else %}
        <div class="no-items">
            <p>Записей пока нет.</p>
        </div>
    {% endif %}
</div>

{% if total_pages > 1 %}
<div class="pagination">
    {% if current_page > 1 %}
        <a href="{{ url(nav_item.url ~ '?page=' ~ (current_page - 1) ~ (query_string ? '&' ~ query_string : '')) }}" class="pagination-prev">← Назад</a>
    {% endif %}
    
    <span class="pagination-info">Страница {{ current_page }} из {{ total_pages }}</span>
    
    {% if current_page < total_pages %}
        <a href="{{ url(nav_item.url ~ '?page=' ~ (current_page + 1) ~ (query_string ? '&' ~ query_string : '')) }}" class="pagination-next">Вперед →</a>
    {% endif %}
</div>
{% endif %}
{% endblock %}