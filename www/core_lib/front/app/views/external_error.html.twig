{# external page error fallback #}
{% extends 'base.html.twig' %}

{% block content %}
<section class="max-w-2xl mx-auto px-4 py-16 text-center">
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-8">
        <i class="fas fa-exclamation-triangle text-yellow-500 text-5xl mb-4 block"></i>
        <h2 class="text-xl font-semibold text-yellow-800 mb-2">Data temporarily unavailable</h2>
        <p class="text-yellow-700 text-sm mb-4">
            Could not load data from the external source. Please try again later.
        </p>
        {% if source_url is defined and source_url %}
        <details class="text-left mt-4 text-xs text-yellow-600">
            <summary class="cursor-pointer hover:text-yellow-800">Technical details</summary>
            <p class="mt-2">URL: <code class="bg-yellow-100 px-1 rounded">{{ source_url }}</code></p>
            {% if error is defined %}
            <p class="mt-1">Error: {{ error }}</p>
            {% endif %}
        </details>
        {% endif %}
    </div>
</section>
{% endblock %}
