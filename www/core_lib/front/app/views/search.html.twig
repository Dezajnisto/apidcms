{% extends "base.html.twig" %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
<article style="max-width:800px;margin:0 auto;padding:2rem 1rem">
    <h1 style="margin-bottom:1.5rem">{{ title }}</h1>

    <form method="get" action="" style="margin-bottom:2rem;display:flex;gap:0.5rem">
        <input
            type="text"
            name="q"
            value="{{ query }}"
            placeholder="Поиск по сайту..."
            style="flex:1;padding:0.75rem 1rem;border:1px solid #d6d3d1;border-radius:0.5rem;font-size:1rem;outline:none"
            autofocus
        >
        <button type="submit" style="padding:0.75rem 1.5rem;background:#1c1917;color:#fff;border:none;border-radius:0.5rem;cursor:pointer;font-size:1rem;white-space:nowrap">
            Найти
        </button>
    </form>

    {% if results is not empty %}
        <p style="color:#78716c;margin-bottom:1.5rem;font-size:0.9375rem">Найдено: {{ results_count }}</p>

        {% for item in results %}
            <div style="margin-bottom:1.5rem;padding-bottom:1.5rem;border-bottom:1px solid #e7e5e4">
                <a href="{{ item.url }}" style="font-size:1.125rem;font-weight:600;color:#1c1917;text-decoration:none;display:block;margin-bottom:0.375rem">
                    {{ item.title }}
                </a>
                <p style="color:#78716c;font-size:0.9375rem;line-height:1.6;margin:0">
                    {{ item.snippet|raw }}
                </p>
            </div>
        {% endfor %}

    {% elseif query is not empty %}
        <p style="color:#78716c;text-align:center;padding:3rem 0;font-size:1.0625rem">
            По запросу «<strong>{{ query }}</strong>» ничего не найдено
        </p>
    {% endif %}
</article>
{% endblock %}
