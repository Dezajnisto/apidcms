{% extends "base.html.twig" %}

{% block title %}{{ title }} — AI-помощник{% endblock %}

{% block content %}
<div class="container py-8" style="min-height: calc(100vh - 200px);">
    <div id="ai-chat-app" class="max-w-3xl mx-auto bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        {# Заголовок #}
        <div class="px-6 py-4 border-b border-gray-100 bg-stone-50">
            <h2 class="text-lg font-semibold text-stone-800">🤖 {{ title }}</h2>
            <p class="text-sm text-stone-500 mt-1">Задайте вопрос — я найду ответ на страницах этого сайта</p>
        </div>

        {# Сообщения #}
        <div id="chat-messages" class="px-6 py-4 space-y-4" style="max-height: 55vh; overflow-y: auto;">
            <div class="flex gap-3">
                <div class="w-8 h-8 rounded-full bg-stone-200 flex items-center justify-center text-sm flex-shrink-0">🤖</div>
                <div class="bg-stone-50 rounded-2xl rounded-tl-sm px-4 py-3 max-w-[80%]">
                    <p class="text-stone-700">Привет! Я AI-помощник этого сайта. Спросите меня о чём угодно — я поищу ответ в базе данных сайта.</p>
                </div>
            </div>
        </div>

        {# Быстрые ссылки #}
        <div id="quick-links" class="px-6 py-2 flex gap-2 flex-wrap"></div>

        {# Поле ввода #}
        <div class="px-6 py-4 border-t border-gray-100 bg-white">
            <form id="chat-form" class="flex gap-3">
                <input
                    type="text"
                    id="chat-input"
                    placeholder="Введите ваш вопрос..."
                    class="flex-1 px-4 py-2.5 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-stone-400 focus:border-transparent text-sm"
                    autocomplete="off"
                >
                <button
                    type="submit"
                    id="chat-send"
                    class="px-5 py-2.5 bg-stone-800 text-white rounded-xl hover:bg-stone-700 transition text-sm font-medium disabled:opacity-50 disabled:cursor-not-allowed"
                >
                    Отправить
                </button>
            </form>
        </div>
    </div>
</div>

{# Стили #}
<style>
    #chat-messages::-webkit-scrollbar { width: 4px; }
    #chat-messages::-webkit-scrollbar-thumb { background: #d6d3d1; border-radius: 2px; }
    .ai-message p { margin: 0.25rem 0; }
    .ai-message p:first-child { margin-top: 0; }
    .ai-message p:last-child { margin-bottom: 0; }
    .ai-message code { background: #f5f5f4; padding: 0.125rem 0.375rem; border-radius: 0.25rem; font-size: 0.875rem; }
    .ai-message pre { background: #1c1917; color: #fafaf9; padding: 0.75rem 1rem; border-radius: 0.5rem; overflow-x: auto; font-size: 0.8125rem; }
    .ai-message table { width: 100%; border-collapse: collapse; margin: 0.5rem 0; font-size: 0.875rem; }
    .ai-message th, .ai-message td { border: 1px solid #e7e5e4; padding: 0.5rem 0.75rem; text-align: left; }
    .ai-message th { background: #fafaf9; font-weight: 600; }
    .ai-message ul, .ai-message ol { padding-left: 1.25rem; margin: 0.25rem 0; }
    .ai-message strong { color: #1c1917; }
    .ai-message a { color: #78716c; text-decoration: underline; }
    .typing-dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #a8a29e; animation: typing-bounce 1.4s infinite ease-in-out both; margin: 0 1px; }
    .typing-dot:nth-child(1) { animation-delay: -0.32s; }
    .typing-dot:nth-child(2) { animation-delay: -0.16s; }
    @keyframes typing-bounce { 0%, 80%, 100% { transform: scale(0); } 40% { transform: scale(1); } }
    .quick-link-btn { display: inline-flex; align-items: center; padding: 0.375rem 0.75rem; background: #f5f5f4; border: 1px solid #e7e5e4; border-radius: 9999px; font-size: 0.8125rem; color: #57534e; cursor: pointer; transition: all 0.15s; }
    .quick-link-btn:hover { background: #e7e5e4; color: #1c1917; }
</style>

<script src="/static/ai-chat.js"></script>
{% endblock %}
