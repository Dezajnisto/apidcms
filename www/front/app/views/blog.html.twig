{% extends "base.html.twig" %}

{% block title %}{{ title }} | {{ site_title }}{% endblock %}

{% block content %}
<div class="page-header">
    <h1>{{ title }}</h1>
    {% if nav_item.page_type == 'blog' %}
        <p class="page-subtitle">Блог и новости</p>
    {% endif %}
</div>

<div class="content-grid">
    {% if items %}
        {% for item in items %}
            <article class="grid-item">
                {% if item.featured_image %}
                    <div class="grid-item-image">
                        <img src="{{ url('storage/uploads/' ~ item.featured_image) }}" alt="{{ item.title }}">
                    </div>
                {% endif %}
                
                <div class="grid-item-content">
                    <h2 class="grid-item-title">
                        <a href="{{ url(nav_item.url ~ '/' ~ item.slug) }}">{{ item.title }}</a>
                    </h2>
                    
                    <div class="grid-item-meta">
                        {% if item.created_at %}
                            <time datetime="{{ item.created_at|date('Y-m-d') }}">
                                {{ item.created_at|date('d.m.Y') }}
                            </time>
                        {% endif %}
                    </div>
                    
                    {% if item.excerpt %}
                        <div class="grid-item-excerpt">
                            {{ item.excerpt|slice(0, 150) }}{% if item.excerpt|length > 150 %}...{% endif %}
                        </div>
                    {% elseif item.content %}
                        <div class="grid-item-excerpt">
                            {{ item.content|striptags|slice(0, 150) }}...
                        </div>
                    {% endif %}
                    
                    <a href="{{ url(nav_item.url ~ '/' ~ item.slug) }}" class="read-more">Подробнее</a>
                </div>
            </article>
        {% endfor %}
    {% else %}
        <div class="no-items">
            <p>Записей пока нет.</p>
        </div>
    {% endif %}
</div>

{% if total_pages > 1 %}
<div class="pagination">
    {% if current_page > 1 %}
        <a href="{{ url(nav_item.url ~ '/page/' ~ (current_page - 1) ~ (query_string ? '?' ~ query_string : '')) }}" class="pagination-prev">← Назад</a>
    {% endif %}
    
    <span class="pagination-info">Страница {{ current_page }} из {{ total_pages }}</span>
    
    {% if current_page < total_pages %}
        <a href="{{ url(nav_item.url ~ '/page/' ~ (current_page + 1) ~ (query_string ? '?' ~ query_string : '')) }}" class="pagination-next">Вперед →</a>
    {% endif %}
</div>
{% endif %}

<style>
    .page-header {
        margin-bottom: 40px;
        padding-bottom: 20px;
        border-bottom: 2px solid #e0e0e0;
        max-width: 1200px;
        margin-left: auto;
        margin-right: auto;
        padding-left: 20px;
        padding-right: 20px;
    }

    .page-header h1 {
        font-size: 2.2em;
        color: #333;
        margin: 0 0 10px 0;
    }

    .page-subtitle {
        color: #888;
        font-size: 1.1em;
        margin: 0;
    }

    .content-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
        margin-bottom: 40px;
        max-width: 1200px;
        margin-left: auto;
        margin-right: auto;
        padding-left: 20px;
        padding-right: 20px;
    }

    .grid-item {
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 15px rgba(0,0,0,0.08);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        display: flex;
        flex-direction: column;
    }

    .grid-item:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.12);
    }

    .grid-item-image {
        width: 100%;
        height: 220px;
        overflow: hidden;
    }

    .grid-item-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .grid-item:hover .grid-item-image img {
        transform: scale(1.05);
    }

    .grid-item-content {
        padding: 25px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .grid-item-title {
        font-size: 1.3em;
        margin: 0 0 12px 0;
        line-height: 1.4;
    }

    .grid-item-title a {
        color: #333;
        text-decoration: none;
        transition: color 0.2s;
    }

    .grid-item-title a:hover {
        color: #007bff;
    }

    .grid-item-meta {
        margin-bottom: 15px;
        font-size: 0.9em;
        color: #999;
    }

    .grid-item-meta time {
        display: inline-block;
    }

    .grid-item-excerpt {
        color: #666;
        line-height: 1.6;
        margin-bottom: 20px;
        flex: 1;
    }

    .read-more {
        display: inline-block;
        padding: 10px 25px;
        background: #007bff;
        color: #fff;
        text-decoration: none;
        border-radius: 6px;
        font-size: 0.95em;
        transition: background 0.2s;
        align-self: flex-start;
    }

    .read-more:hover {
        background: #0056b3;
    }

    .no-items {
        grid-column: 1 / -1;
        text-align: center;
        padding: 60px 20px;
        background: #f9f9f9;
        border-radius: 12px;
    }

    .no-items p {
        font-size: 1.2em;
        color: #888;
        margin: 0;
    }

    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 20px;
        padding: 30px 0;
        border-top: 1px solid #e0e0e0;
        max-width: 1200px;
        margin-left: auto;
        margin-right: auto;
        padding-left: 20px;
        padding-right: 20px;
    }

    .pagination-prev,
    .pagination-next {
        display: inline-block;
        padding: 12px 25px;
        background: #f0f0f0;
        color: #333;
        text-decoration: none;
        border-radius: 6px;
        transition: background 0.2s, color 0.2s;
        font-size: 0.95em;
    }

    .pagination-prev:hover,
    .pagination-next:hover {
        background: #007bff;
        color: #fff;
    }

    .pagination-info {
        font-size: 0.95em;
        color: #888;
    }

    @media (max-width: 1024px) {
        .content-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .content-grid {
            grid-template-columns: 1fr;
            gap: 20px;
            padding-left: 15px;
            padding-right: 15px;
        }

        .page-header h1 {
            font-size: 1.8em;
        }

        .grid-item-image {
            height: 180px;
        }

        .grid-item-content {
            padding: 20px;
        }

        .pagination {
            padding-left: 15px;
            padding-right: 15px;
        }
    }

    @media (max-width: 480px) {
        .pagination {
            flex-direction: column;
            gap: 15px;
        }

        .grid-item-image {
            height: 160px;
        }
    }
</style>
{% endblock %}