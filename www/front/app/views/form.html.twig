{% extends "base.html.twig" %}

{% block title %}{{ meta_title is defined ? meta_title : title }}{% endblock %}

{% if meta_description is defined and meta_description %}
{% block meta_description %}{{ meta_description }}{% endblock %}
{% endif %}

{% block content %}
<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-lg shadow-sm border p-6">

        {# --- Контент страницы из pages (если есть) --- #}
        {% if pageContent is not empty %}
            <div class="page-content mb-8">
                {{ pageContent|raw }}
            </div>
        {% endif %}

        {# --- Заголовок формы --- #}
        {% if pageContent is empty %}
            <h1 class="text-2xl font-bold text-gray-900 mb-2">{{ title }}</h1>
        {% endif %}

        {% if config.form_title %}
            <h2 class="text-xl font-semibold text-gray-800 mb-2">{{ config.form_title }}</h2>
        {% endif %}
        {% if config.form_description %}
            <p class="text-gray-600 mb-6">{{ config.form_description }}</p>
        {% endif %}

        {# Показываем общие ошибки #}
        {% if errors is defined and errors.general %}
            <div class="bg-red-50 border border-red-200 rounded-md p-4 mb-6">
                <div class="text-red-700">{{ errors.general }}</div>
            </div>
        {% endif %}

        {{ form_html|raw }}

    </div>
</div>
{% endblock %}
