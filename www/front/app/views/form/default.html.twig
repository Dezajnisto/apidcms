{% extends "form/_base.html.twig" %}

{% block form_content %}
<form method="post" action="{{ action|default('/form-handler') }}"
      class="{{ form_class|default('space-y-6') }}"
      data-form="{{ form_name }}"
      data-success-message="{{ success_message|e('html_attr') }}"
      {% if form_attrs %}{{ form_attrs|raw }}{% endif %}
      novalidate>

    <input type="hidden" name="form_name" value="{{ form_name }}">

    {% if enable_csrf %}
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    {% endif %}

    {% for field_name, field in fields %}
        {% if field_name in hidden_fields|default([]) %}
            <input type="hidden" name="{{ field_name }}" value="{{ field_defaults[field_name]|default('') }}">
        {% else %}
            {% set field = field|merge(field_overrides[field_name]|default({})) %}
            {% set field_class = field_class|default('w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition') %}
            {% set field_error_class = field_error_class|default('border-red-400 focus:ring-red-400') %}
            {% set label_class = label_class|default('block text-sm font-medium text-gray-700 mb-1.5') %}

            {% include 'form/fields/' ~ field.type ~ '.html.twig' with {field: field, field_name: field_name} %}
        {% endif %}
    {% endfor %}

    {% if show_consent %}
        {% include 'form/fields/consent.html.twig' %}
    {% endif %}

    <div class="form-submit pt-2">
        <button type="submit"
                class="{{ submit_class|default('w-full bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-3 rounded-lg transition duration-200') }}">
            {{ submit_text|default('Отправить') }}
        </button>
    </div>
</form>
{% endblock %}
