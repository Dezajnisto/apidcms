{# form/messages.html.twig — сообщения об успехе/ошибке #}
{# Сообщения привязаны к имени формы, чтобы несколько форм на странице не конфликтовали #}
{% if session.form_success is defined and session.form_success == form_name %}
    <div class="form-message form-success mb-4 p-4 bg-green-50 border border-green-200 rounded-lg">
        <div class="flex items-center">
            <svg class="w-5 h-5 text-green-500 mr-2 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span class="text-green-800">{{ session.form_message|default(success_message|default('Форма успешно отправлена!')) }}</span>
        </div>
    </div>
    {% set _ = session.remove('form_success') %}
    {% set _ = session.remove('form_message') %}
{% endif %}

{% if session.form_error is defined and session.form_error == form_name %}
    <div class="form-message form-error mb-4 p-4 bg-red-50 border border-red-200 rounded-lg">
        <div class="flex items-center">
            <svg class="w-5 h-5 text-red-500 mr-2 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span class="text-red-800">{{ session.form_error_message }}</span>
        </div>
    </div>
    {% set _ = session.remove('form_error') %}
    {% set _ = session.remove('form_error_message') %}
    {% set _ = session.remove('form_data') %}
{% endif %}
