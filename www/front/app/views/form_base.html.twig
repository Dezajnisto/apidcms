{# form_base.html.twig #}
<div class="ajax-form-container">
    {% if session.form_success is defined and session.form_success %}
        <div class="mb-4 bg-green-50 border border-green-200 rounded-lg p-4">
            <div class="flex items-center">
                <svg class="w-5 h-5 text-green-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-green-800 font-medium">{{ session.form_message|default('Форма успешно отправлена!') }}</span>
            </div>
        </div>
        {# Очищаем сообщение #}
        {% set _ = session.remove('form_success') %}
        {% set _ = session.remove('form_message') %}
    {% endif %}

    {% if session.form_error is defined %}
        <div class="mb-4 bg-red-50 border border-red-200 rounded-lg p-4">
            <div class="flex items-center">
                <svg class="w-5 h-5 text-red-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span class="text-red-800">{{ session.form_error }}</span>
            </div>
        </div>
        {% set _ = session.remove('form_error') %}
        {% set _ = session.remove('form_data') %}
    {% endif %}

    {# Контент формы #}
    {% block form_content %}{% endblock %}
</div>

{# Подключение AJAX скрипта #}
<script src="{{ asset('js/form-ajax.js') }}"></script>