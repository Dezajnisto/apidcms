{% extends "base.html.twig" %}

{% block content %}

{# Вывод сообщений об успехе/ошибке #}
{% if session.form_success is defined and session.form_success %}
    <div class="mb-4 p-4 bg-green-100 border border-green-400 text-green-700 rounded">
        {{ session.form_message|default('Форма успешно отправлена!') }}
    </div>
    {# Очищаем сообщение после показа #}
    {% set _ = session.remove('form_success') %}
    {% set _ = session.remove('form_message') %}
{% endif %}

{% if session.form_error is defined %}
    <div class="mb-4 p-4 bg-red-100 border border-red-400 text-red-700 rounded">
        {{ session.form_error }}
    </div>
    {# Очищаем ошибку после показа #}
    {% set _ = session.remove('form_error') %}
    {% set _ = session.remove('form_data') %}
{% endif %}


<!-- Hero Promo Section -->
<section class="min-h-screen bg-gradient-to-br from-purple-900 via-primary-purple to-primary-magenta text-white py-16" id="promo">
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
            <!-- Main Promo Block -->
            <div class="relative rounded-2xl overflow-hidden shadow-2xl group h-96 lg:h-full">
                <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent z-10"></div>
                <img src="{{ items[0].image }}" 
                     alt="{{ items[0].title }}"
                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
                <div class="absolute inset-0 z-20 flex flex-col justify-end p-8">
                    <h2 class="font-heading text-4xl lg:text-5xl font-bold mb-4">{{ items[0].title }}</h2>
                    <p class="text-xl opacity-90">{{ items[0].description }}</p>
                </div>
            </div>

            <!-- Right Side Blocks -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Top Right Blocks -->
                <div class="bg-white/10 backdrop-blur-sm rounded-2xl shadow-xl p-6 flex items-center justify-center text-center border border-white/20">
                    <h3 class="font-heading text-2xl">{{ items[1].title }}</h3>
                </div>
                <div class="rounded-2xl overflow-hidden shadow-xl h-48 group">
                    <img src="{{ items[1].image }}" 
                         alt="{{ items[1].title }}"
                         class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                </div>

                <!-- Bottom Right Blocks -->
                <div class="rounded-2xl overflow-hidden shadow-xl h-48 group">
                    <img src="{{ items[2].image }}" 
                         alt="{{ items[2].title }}"
                         class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                </div>
                <div class="bg-white/10 backdrop-blur-sm rounded-2xl shadow-xl p-6 flex items-center justify-center text-center border border-white/20">
                    <h3 class="font-heading text-2xl">{{ items[2].title }}</h3>
                </div>
            </div>
        </div>

        <!-- Second Row -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Left Side Blocks -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="rounded-2xl overflow-hidden shadow-xl h-48 group">
                    <img src="{{ items[3].image }}" 
                         alt="{{ items[3].title }}"
                         class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                </div>
                <div class="bg-white/10 backdrop-blur-sm rounded-2xl shadow-xl p-6 flex items-center justify-center text-center border border-white/20">
                    <h3 class="font-heading text-2xl">{{ items[3].title }}</h3>
                </div>

                <div class="bg-white/10 backdrop-blur-sm rounded-2xl shadow-xl p-6 border border-white/20">
                    <h4 class="font-heading text-xl mb-2">{{ items[5].title }}</h4>
                    <p class="opacity-90">{{ items[5].description }}</p>
                </div>
                <div class="rounded-2xl overflow-hidden shadow-xl h-48 group">
                    <img src="{{ items[5].image }}" 
                         alt="{{ items[5].title }}"
                         class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                </div>
            </div>

            <!-- Right Main Block -->
            <div class="relative rounded-2xl overflow-hidden shadow-2xl group h-96">
                <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent z-10"></div>
                <img src="{{ items[4].image }}" 
                     alt="{{ items[4].title }}"
                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
                <div class="absolute inset-0 z-20 flex flex-col justify-end p-8">
                    <h2 class="font-heading text-4xl font-bold mb-4">{{ items[4].title }}</h2>
                    <p class="text-xl opacity-90">{{ items[4].description }}</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Reasons Section -->
<section class="py-16 bg-gradient-to-br from-primary-magenta to-pink-600 text-white" id="reason">
    <div class="container mx-auto px-4">
        <div class="text-center mb-12">
            <h2 class="font-heading text-4xl font-bold mb-4">{{ items[6].title }}</h2>
            <p class="text-xl max-w-3xl mx-auto">{{ items[6].description }}</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {% for i in 7..12 %}
            <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 text-center border border-white/20 hover:bg-white/20 transition-all duration-300 transform hover:-translate-y-1">
                <div class="w-20 h-20 mx-auto mb-4 bg-white rounded-full flex items-center justify-center">
                    <img src="{{ items[i].image }}" 
                         alt="{{ items[i].title }}"
                         class="w-12 h-12 object-contain">
                </div>
                <h4 class="font-heading text-xl font-semibold">{{ items[i].title }}</h4>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- Advantages Section -->
<section class="py-16 bg-gradient-to-br from-gray-50 to-white" id="advantages">
    <div class="container mx-auto px-4">
        <div class="text-center mb-12">
            <h2 class="font-heading text-4xl font-bold text-gray-800 mb-4">{{ items[13].title }}</h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">{{ items[13].description }}</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {% set gradient_classes = [
                'from-purple-600 to-primary-magenta',
                'from-primary-magenta to-pink-500',
                'from-pink-500 to-rose-500',
                'from-purple-700 to-primary-magenta',
                'from-primary-magenta to-rose-600',
                'from-purple-800 to-pink-600'
            ] %}
            
            {% for i in 14..19 %}
            <div class="bg-gradient-to-br {{ gradient_classes[loop.index0] }} text-white rounded-2xl p-8 text-center shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
                <div class="w-16 h-16 mx-auto mb-4 bg-white rounded-full flex items-center justify-center">
                    <img src="{{ items[i].image }}" 
                         alt="{{ items[i].title }}"
                         class="w-10 h-10 object-contain">
                </div>
                <h3 class="font-heading text-2xl font-bold mb-4">{{ items[i].title }}</h3>
                <p class="text-white text-opacity-90">{{ items[i].description }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- Call to Action 1 -->
<section class="py-16 bg-gradient-to-br from-purple-800 via-primary-purple to-primary-magenta text-white" id="call-01">
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div class="text-center lg:text-left">
                <div class="relative">
                    <div class="absolute -inset-4 bg-white/20 rounded-full blur-lg"></div>
                    <img src="{{ items[20].image }}" 
                         alt="{{ items[20].title }}"
                         class="relative w-64 h-64 mx-auto lg:mx-0 object-contain">
                </div>
            </div>
            <div class="text-center lg:text-left">
                <h3 class="font-heading text-3xl font-bold mb-4">{{ items[20].title }}</h3>
                <p class="text-xl mb-8">{{ items[20].description }}</p>
                <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-1 shadow-2xl border border-white/20">

{# Встраиваем форму обратной связи #}
    <h3 class="text-xl font-bold mb-4">Обратная связь</h3>
{{ render_form('contacts', config) }}
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Popular Section -->
<section class="py-16 bg-white" id="popular">
    <div class="container mx-auto px-4">
        <h2 class="font-heading text-4xl font-bold text-center text-gray-800 mb-12">{{ items[21].title }}</h2>
        
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
            {% for i in 22..27 %}
            <div class="text-center group hover:transform hover:scale-105 transition-all duration-300">
                <div class="w-20 h-20 mx-auto mb-4 bg-gradient-to-br from-primary-purple to-primary-pink rounded-full flex items-center justify-center group-hover:shadow-lg transition-shadow shadow-md">
                    <img src="{{ items[i].image }}" 
                         alt="{{ items[i].title }}"
                         class="w-10 h-10 object-contain">
                </div>
                <p class="font-body text-gray-700 font-medium">{{ items[i].title }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- How It Works -->
<section class="py-16 bg-gradient-to-br from-purple-600 via-primary-magenta to-pink-600 text-white" id="how">
    <div class="container mx-auto px-4">
        <div class="text-center mb-12">
            <h2 class="font-heading text-4xl font-bold mb-4">{{ items[28].title }}</h2>
            <p class="text-xl max-w-3xl mx-auto">{{ items[28].description }}</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
            {% for i in 29..31 %}
            <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-8 text-center border border-white/20 hover:bg-white/20 transition-all duration-300 transform hover:-translate-y-1">
                <div class="w-20 h-20 mx-auto mb-6 bg-white rounded-full flex items-center justify-center">
                    <img src="{{ items[i].image }}" 
                         alt="{{ items[i].title }}"
                         class="w-10 h-10 object-contain">
                </div>
                <h5 class="font-heading text-xl font-bold mb-4">{{ items[i].title }}</h5>
                <p class="text-white text-opacity-90">{{ items[i].description }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- Video Section -->
<section class="py-16 bg-gradient-to-br from-gray-100 to-white" id="video">
    <div class="container mx-auto px-4">
        <div class="text-center mb-12">
            <h3 class="font-heading text-3xl font-bold text-gray-800 mb-4">{{ items[32].title }}</h3>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">{{ items[32].description }}</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {% for i in 33..36 %}
                {% if items[i] is defined and items[i].description is not empty %}
                <div class="bg-white rounded-2xl shadow-lg p-6 border border-gray-200">
                    <div class="relative rounded-lg overflow-hidden" style="padding-bottom: 56.25%; height: 0;">
                        {{ items[i].description|raw }}
                    </div>
                </div>
                {% else %}
                <div class="bg-white rounded-2xl shadow-lg p-6 border border-gray-200">
                    <div class="relative rounded-lg overflow-hidden bg-gray-200 flex items-center justify-center" style="padding-bottom: 56.25%; height: 0;">
                        <div class="absolute inset-0 flex items-center justify-center">
                            <span class="text-gray-500">Видео скоро будет добавлено</span>
                        </div>
                    </div>
                </div>
                {% endif %}
            {% endfor %}
        </div>
    </div>
</section>

<!-- Examples Section -->
<section class="py-16 bg-gradient-to-br from-purple-900 via-primary-purple to-primary-magenta text-white" id="examples">
    <div class="container mx-auto px-4">
        <div class="text-center mb-12">
            <h2 class="font-heading text-4xl font-bold mb-4">{{ items[37].title }}</h2>
            <p class="text-xl max-w-3xl mx-auto">{{ items[37].description }}</p>
        </div>

        <!-- Poetry block will be inserted here -->
        {% block poetry %}{{ poetry|default('')|raw }}{% endblock %}

        <div class="text-center mt-12">
            <a href="{{ items[43].description }}" 
               class="inline-block bg-white text-primary-purple font-heading text-lg font-bold px-8 py-4 rounded-full hover:bg-gray-100 transform hover:scale-105 transition-all duration-300 shadow-lg hover:shadow-xl">
                {{ items[43].title }}
            </a>
        </div>
    </div>
</section>

<!-- Reviews Section -->
<section class="py-16 bg-gradient-to-br from-white to-gray-50" id="reviews">
    <div class="container mx-auto px-4">
        <div class="text-center mb-12">
            <h2 class="font-heading text-4xl font-bold text-gray-800 mb-4">{{ items[44].title }}</h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">{{ items[44].description }}</p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6 mb-12">
            {% for i in 45..49 %}
            <div class="group relative rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
                <img src="{{ items[i].image }}" 
                     alt="Review {{ loop.index }}"
                     class="w-full h-48 object-cover group-hover:scale-110 transition-transform duration-500">
                <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-300"></div>
            </div>
            {% endfor %}
        </div>

        <div class="text-center">
            <a href="{{ items[50].description }}" 
               class="inline-block bg-gradient-to-r from-primary-purple to-primary-pink text-white font-heading text-lg font-bold px-8 py-4 rounded-full hover:shadow-xl transform hover:scale-105 transition-all duration-300 shadow-lg">
                {{ items[50].title }}
            </a>
        </div>
    </div>
</section>

<!-- Final Call to Action -->
<section class="py-16 bg-gradient-to-br from-primary-magenta via-pink-600 to-rose-600 text-white" id="call-02">
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div class="text-center lg:text-left">
                <div class="relative">
                    <div class="absolute -inset-4 bg-white/20 rounded-full blur-lg"></div>
                    <img src="{{ items[51].image }}" 
                         alt="{{ items[51].title }}"
                         class="relative w-64 h-64 mx-auto lg:mx-0 object-contain">
                </div>
            </div>
            <div class="text-center lg:text-left">
                <h3 class="font-heading text-3xl font-bold mb-4">{{ items[51].title }}</h3>
                <p class="text-xl mb-8">{{ items[51].description }}</p>
                <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-1 shadow-2xl border border-white/20">
                    <iframe 
                        src="https://crm.dezajno.ru?entryPoint=leadCaptureForm&id=682d85c5dd17627ff" 
                        width="100%" 
                        height="400" 
                        style="border: none; border-radius: 16px;"
                        scrolling="no">
                    </iframe>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}