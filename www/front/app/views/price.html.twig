</section>

<!-- ============================================
БЛОК 4 — ДОПОЛНИТЕЛЬНЫЕ УСЛУГИ (ТАБЛИЦА)
============================================ -->
<section class="price-section" style="padding-top: 40px; padding-bottom: 0;">
 <div class="price-container">
 <h2 class="section-title">Дополнительные форматы и оформление</h2>
 <div class="services-table-wrap">
 <table class="services-table">
 <tbody>
 <tr>
 <td>Дизайн открытки со стихами</td>
 <td>500 ₽</td>
 </tr>
 <tr>
 <td>Написание акростиха (по первым буквам имени)</td>
 <td>От 1 000 ₽</td>
 </tr>
 <tr>
 <td>Создание караоке-версии песни</td>
 <td>3 000 ₽</td>
 </tr>
 </tbody>
 </table>
 </div>
 </div>
</section>

<!-- ============================================
БЛОК 5 — ПРОМОБЛОК (Lead Magnet)
============================================ -->
<section class="price-section" style="padding-top: 40px; padding-bottom: 60px;">
 <div class="price-container">
 <div class="price-promo">
 <div class="price-promo-text">
 <h2>Скидка 30% на первый заказ</h2>
 <p>
 Оставьте заявку сейчас. Мы свяжемся с вами в течение 15 минут,
 обсудим идею и забронируем за вами скидку. Оплата только после
 согласования деталей.
 </p>
 </div>
 <form class="price-promo-form" onsubmit="event.preventDefault(); alert('Спасибо! Мы свяжемся с вами в ближайшее время.'); this.reset();">
 <input type="text" name="name" placeholder="Ваше имя" required>
 <input type="tel" name="phone" placeholder="Номер телефона" required>
 <button type="submit" class="price-btn price-btn-white">Забронировать скидку</button>
 </form>
 </div>
 </div>
</section>

<!-- ============================================
МОДАЛЬНОЕ ОКНО
============================================ -->
<div class="price-modal-overlay" id="priceOrderModal">
 <div class="price-modal">
 <button class="price-modal-close" onclick="closePriceModal()">✕</button>
 <h3>Заказ</h3>
 <p id="priceModalProduct">—</p>
 <form class="price-modal-form" onsubmit="event.preventDefault(); alert('Спасибо! Мы свяжемся с вами для подтверждения заказа.'); closePriceModal(); this.reset();">
 <input type="text" name="name" placeholder="Ваше имя" required>
 <input type="tel" name="phone" placeholder="Номер телефона" required>
 <button type="submit" class="price-btn price-btn-primary">Отправить</button>
 </form>
 </div>
</div>

<script>
function openPriceModal(product) {
 document.getElementById('priceModalProduct').textContent = '«' + product + '»';
 document.getElementById('priceOrderModal').classList.add('open');
}
function closePriceModal() {
 document.getElementById('priceOrderModal').classList.remove('open');
}
document.getElementById('priceOrderModal').addEventListener('click', function(e) {
 if (e.target === this) closePriceModal();
});
document.addEventListener('keydown', function(e) {
 if (e.key === 'Escape') closePriceModal();
});
</script>

{% endblock %}
